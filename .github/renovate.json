{
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchCategories": [
        "docker"
      ],
      "enabled": true
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "groupName": "All Docker image updates"
    }
  ],
  "semanticCommits": "enabled",
  "semanticCommitScope": "deps",
  "timezone": "Europe/Amsterdam",
  "schedule": [
    "after 10pm every weekday",
    "before 6am every weekday"
  ]
}
