#!/bin/bash
#! vim: ft=sh

set -euo pipefail

UPS="{{ nut_ups_name }}@localhost"
THRESHOLD={{ nut_shutdown_threshold | int }}

# Try to get current battery charge
CHARGE=$(upsc "$UPS" battery.charge 2>/dev/null | tr -dc '0-9')

if [[ -z "${CHARGE}" ]]; then
  logger -t ups-battery-monitor "Unable to read battery.charge from $UPS"
  exit 0
fi

# If on AC power, do nothing (prevents shutdown when recharging at low %)
ONLINE=$(upsc "$UPS" ups.status 2>/dev/null | tr '[:space:]' '\n' | grep -E '^OL$' || true)
if [[ -n "$ONLINE" ]]; then
  exit 0
fi

if [[ "$CHARGE" -le "$THRESHOLD" ]]; then
  logger -t ups-battery-monitor "UPS battery at ${CHARGE}% (<= ${THRESHOLD}%) and on battery — initiating shutdown"
  /sbin/shutdown -h now "UPS battery low (${CHARGE}%)"
fi
