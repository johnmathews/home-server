#!/usr/bin/env bash
# vim: ft=sh

set -Eeuo pipefail

# upssched passes a single argument (action name) and exports UPSNAME.
ACTION="${1:-unknown}"
UPS="${UPSNAME:-unknown}"

log() { logger -t upssched "UPS=${UPS} ACTION=${ACTION} $*"; }

case "$ACTION" in
  onbatt)
    log "ONBATT: UPS is on battery"
    ;;
  online)
    log "ONLINE: UPS is back on mains"
    ;;
  lowbatt)
    log "LOWBATT: Battery low"
    ;;
  fsd)
    log "FSD: Forced shutdown in progress"
    ;;
  commbad)
    log "COMMBAD: Communications lost"
    ;;
  commok)
    log "COMMOK: Communications restored"
    ;;
  *)
    log "UNKNOWN ACTION"
    ;;
esac

# Pushover integration
PO_MSG="UPS ${UPS}: ${ACTION}"
PO_ARGS=(
  --data-urlencode "token={{ vault_pushover_pve_application_token }}" \
  --data-urlencode "user={{ vault_pushover_user_key }}" \
  --data-urlencode "title=UPS ${UPS}" \
  --data-urlencode "message=${PO_MSG}" \
  --data-urlencode "priority=1"                    #  -2 quiet, -1 low, 0 normal, 1 high, 2 emergency
  --data-urlencode "sound=pushover"                # or bike, siren, etc.
)
curl -sS "${PO_ARGS[@]}" https://api.pushover.net/1/messages.json >/dev/null || true

