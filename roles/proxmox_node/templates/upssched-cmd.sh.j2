#!/usr/bin/env bash
# vim: ft=sh

set -Eeuo pipefail

umask 022
export PATH=/usr/sbin:/usr/bin:/sbin:/bin

# upssched passes a single argument (action name) and exports UPSNAME.
ACTION="${1:-unknown}"
UPS="${UPSNAME:-unknown}"

# Normalize the UPS target: if UPS already includes "@", use it as-is; otherwise append @localhost
UPS_TARGET="$UPS"
case "$UPS_TARGET" in
  *@*) : ;;                            # already like "ups@host"
  *)    UPS_TARGET="${UPS}@localhost" ;;
esac

log() { logger -t upssched "UPS=${UPS} ACTION=${ACTION} $*"; }

case "$ACTION" in
  onbatt)
    log "ONBATT: UPS is on battery"
    ;;
  online)
    log "ONLINE: UPS is back on mains"
    ;;
  lowbatt)
    log "LOWBATT: Battery low"
    ;;
  fsd)
    log "FSD: Forced shutdown in progress"
    ;;
  commbad)
    log "COMMBAD: Communications lost"
    ;;
  commok)
    log "COMMOK: Communications restored"
    ;;
  *)
    log "UNKNOWN ACTION"
    ;;
esac

