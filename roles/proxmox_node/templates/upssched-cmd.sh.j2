#!/usr/bin/env bash
set -Eeuo pipefail

# upssched passes a single argument (action name) and exports UPSNAME.
ACTION="${1:-unknown}"
UPS="${UPSNAME:-unknown}"

log() { logger -t upssched "UPS=${UPS} ACTION=${ACTION} $*"; }

case "$ACTION" in
  onbatt)
    log "ONBATT: UPS is on battery"
    ;;
  online)
    log "ONLINE: UPS is back on mains"
    ;;
  lowbatt)
    log "LOWBATT: Battery low"
    ;;
  fsd)
    log "FSD: Forced shutdown in progress"
    ;;
  commbad)
    log "COMMBAD: Communications lost"
    ;;
  commok)
    log "COMMOK: Communications restored"
    ;;
  *)
    log "UNKNOWN ACTION"
    ;;
esac

