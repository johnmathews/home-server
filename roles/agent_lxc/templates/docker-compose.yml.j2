# vim: ft=yaml
# agent_lxc/templates/docker-compose.yml.j2
# Monitoring stack + Syncthing — NanoClaw runs natively as a systemd user service

services:

  portainer-agent:
    image: portainer/agent:{{ portainer_agent_version }}
    container_name: portainer_agent
    restart: always
    ports:
      - "9001:9001"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /var/lib/docker/volumes:/var/lib/docker/volumes
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
  relay:
    image: ghcr.io/johnmathews/relay:{{ relay_version }}
    container_name: relay
    restart: unless-stopped
    # Image's relay user is uid 10001; this override runs the container as
    # the same uid:gid syncthing uses (PUID=1000), so the bind-mounted
    # /srv/apps/relay/{data,.pi} directories are read/writable without a
    # chown dance. Adjust if your LXC user differs.
    user: "1000:1000"
    ports:
      - "7800:7800"
    environment:
      # RELAY_HOST=0.0.0.0 and PI_AGENT_SDK=1 are baked into the image
      # ENV (ADR-51). Override RELAY_OTEL_EXPORT here if you wire up
      # Langfuse on this LXC; see docs/observability.md in the relay
      # repo.
      RELAY_PORT: "7800"
      # RELAY_OTEL_EXPORT: langfuse
      # RELAY_LANGFUSE_HOST: http://host.docker.internal:3000
      # RELAY_LANGFUSE_PUBLIC_KEY: pk-lf-...
      # RELAY_LANGFUSE_SECRET_KEY: sk-lf-...
    volumes:
      # SQLite event store (the orchestrator's source of truth).
      - /srv/apps/relay/data:/app/.relay
      # Pi OAuth credential — populate once on the host before first
      # `docker compose up`:
      #   sudo -u "#1000" env PI_AGENT_SDK=1 HOME=/srv/apps/relay pi
      # (completes OAuth in a browser, writes /srv/apps/relay/.pi/agent/auth.json)
      - /srv/apps/relay/.pi:/home/relay/.pi
      # Project trees relay will manage. Relay stores ABSOLUTE project
      # paths in its DB and the in-container agent must see those same
      # paths, so use identity bind mounts (host:container same path),
      # NOT remapping into /workspace or similar. Add one entry per
      # project root you want relay to drive. Common choices on this
      # LXC: the syncthing tree (gets you everything synced from your
      # workstation), or specific subdirs.
      - /srv/apps/syncthing:/srv/apps/syncthing
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  syncthing:
    image: syncthing/syncthing:{{ syncthing_version }}
    container_name: syncthing
    hostname: agent-lxc
    restart: unless-stopped
    network_mode: host
    environment:
      - PUID=1000
      - PGID=1000
      - STNOUPGRADE=1
    volumes:
      - /srv/apps/syncthing:/var/syncthing
      - /srv/apps/nanoclaw:/var/nanoclaw
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:{{ cadvisor_version }}
    container_name: cadvisor
    restart: always
    command:
      - '--housekeeping_interval=30s'
      - '--global_housekeeping_interval=2m'
      - '--docker_only=true'
    ports:
      - "18080:8080"
    volumes:
      - /:/rootfs:ro
      - /sys:/sys:ro
      - /sys/fs/cgroup:/sys/fs/cgroup:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /var/run:/var/run:ro
    privileged: false
    security_opt:
      - no-new-privileges:true
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  alloy:
    image: grafana/alloy:{{ alloy_version }}
    container_name: alloy
    restart: unless-stopped
    environment:
      LOKI_WRITE_ENDPOINT: "http://192.168.2.106:3100/loki/api/v1/push"
      NODE_HOSTNAME: "agent"
      LOG_LEVEL: "warn"
    volumes:
      - ./alloy:/etc/alloy:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /var/log/journal:/var/log/journal:ro
      - /run/log/journal:/run/log/journal:ro
      - /etc/machine-id:/etc/machine-id:ro
    command: >
      run --server.http.listen-addr=0.0.0.0:12345 --stability.level=experimental --storage.path=/var/lib/alloy/data /etc/alloy/config.alloy
    ports:
      - "12345:12345"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

{% for site in mkdocs_sites %}
  mkdocs-{{ site.name }}:
    build: ./mkdocs
    container_name: mkdocs-{{ site.name }}
    working_dir: /docs
    volumes:
      - {{ site.docs_path }}:/docs/docs:rw
      - ./mkdocs/{{ site.name }}/mkdocs.yml:/docs/mkdocs.yml:ro
{% if site.order is defined %}
      - ./mkdocs/{{ site.name }}/.pages:/docs/docs/.pages:ro
{% endif %}
{% if site.date_titles | default(false) %}
      - ./mkdocs/hooks:/docs/hooks:ro
{% endif %}
    ports:
      - "{{ site.port }}:8000"
    restart: unless-stopped
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

{% endfor %}
  node_exporter:
    image: quay.io/prometheus/node-exporter:{{ node_exporter_version }}
    container_name: node_exporter
    command:
      - '--path.rootfs=/host'
      - '--collector.textfile.directory=/textfile'
    ports:
      - "9100:9100"
    pid: host
    restart: unless-stopped
    volumes:
      - '/:/host:ro,rslave'
      - '/var/lib/node_exporter/textfile_collector:/textfile:ro'
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

