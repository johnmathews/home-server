# vim: ft=yaml
# openclaw_lxc/templates/docker-compose.yml.j2
# Monitoring stack + Syncthing — OpenClaw is installed natively via getting-started script

services:
  syncthing:
    image: syncthing/syncthing:{{ syncthing_version }}
    container_name: syncthing
    hostname: agent-lxc
    restart: unless-stopped
    environment:
      - PUID=1000
      - PGID=1000
    volumes:
      - /srv/apps/syncthing:/var/syncthing/config
      - /srv/apps/nanoclaw:/var/syncthing/nanoclaw
    ports:
      - "8384:8384"
      - "22000:22000/tcp"
      - "22000:22000/udp"
      - "21027:21027/udp"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:{{ cadvisor_version }}
    container_name: cadvisor
    restart: always
    ports:
      - "18080:8080"
    volumes:
      - /:/rootfs:ro
      - /sys:/sys:ro
      - /sys/fs/cgroup:/sys/fs/cgroup:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /var/run:/var/run:ro
    privileged: false
    security_opt:
      - no-new-privileges:true
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  alloy:
    image: grafana/alloy:{{ alloy_version }}
    container_name: alloy
    restart: unless-stopped
    environment:
      LOKI_WRITE_ENDPOINT: "http://192.168.2.106:3100/loki/api/v1/push"
      NODE_HOSTNAME: "agent"
      LOG_LEVEL: "warn"
    volumes:
      - ./alloy:/etc/alloy:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /var/log/journal:/var/log/journal:ro
      - /run/log/journal:/run/log/journal:ro
      - /etc/machine-id:/etc/machine-id:ro
    command: >
      run --server.http.listen-addr=0.0.0.0:12345 --storage.path=/var/lib/alloy/data /etc/alloy/config.alloy
    ports:
      - "12345:12345"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

{% for site in mkdocs_sites %}
  mkdocs-{{ site.name }}:
    build: ./mkdocs
    container_name: mkdocs-{{ site.name }}
    working_dir: /docs
    volumes:
      - {{ site.docs_path }}:/docs/docs:rw
      - ./mkdocs/{{ site.name }}/mkdocs.yml:/docs/mkdocs.yml:ro
{% if site.order is defined %}
      - ./mkdocs/{{ site.name }}/.pages:/docs/docs/.pages:ro
{% endif %}
{% if site.date_titles | default(false) %}
      - ./mkdocs/hooks:/docs/hooks:ro
{% endif %}
    ports:
      - "{{ site.port }}:8000"
    restart: unless-stopped
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

{% endfor %}
  node_exporter:
    image: quay.io/prometheus/node-exporter:{{ node_exporter_version }}
    container_name: node_exporter
    command:
      - '--path.rootfs=/host'
      - '--collector.textfile.directory=/textfile'
    ports:
      - "9100:9100"
    pid: host
    restart: unless-stopped
    volumes:
      - '/:/host:ro,rslave'
      - '/var/lib/node_exporter/textfile_collector:/textfile:ro'
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

