# vim: ft=yaml
# document_library_lxc/files/docker-compose.yml
services:

  portainer-agent:
    image: portainer/agent:{{ portainer_agent_version }}
    container_name: portainer_agent
    restart: always
    environment:
      # Shared secret: only the Portainer server (same secret) can control this agent
      AGENT_SECRET: "{{ vault_portainer_agent_secret }}"
    ports:
      - "9001:9001"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  # Library (github.com/johnmathews/library) — the document library app.
  # Own Postgres (library-db); pgdata is local at /srv/apps/library/pgdata.
  library-db:
    container_name: library-db
    image: pgvector/pgvector:pg17
    restart: always
    volumes:
      - "{{ docker_compose_dir }}/library/pgdata:/var/lib/postgresql/data"
    environment:
      POSTGRES_DB: library
      POSTGRES_USER: library
      POSTGRES_PASSWORD: ${LIBRARY_DB_PASSWORD}
      TZ: ${TZ}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U library -d library"]
      interval: 10s
      timeout: 5s
      retries: 5

  # One-shot: applies alembic migrations, exits 0. Safe to re-run on every
  # deploy; webserver/worker wait for it via service_completed_successfully.
  library-migrate:
    container_name: library-migrate
    image: ghcr.io/johnmathews/library:{{ library_version }}
    command: ["alembic", "upgrade", "head"]
    environment:
      LIBRARY_DATABASE_URL: postgresql+asyncpg://library:${LIBRARY_DB_PASSWORD}@library-db:5432/library
    depends_on:
      library-db:
        condition: service_healthy
    restart: "no"

  # Local bge-m3 embeddings for semantic Ask (docs/ask.md). CPU inference;
  # downloads the model (~2 GB) into embedder-cache on first start.
  library-embedder:
    container_name: library-embedder
    image: ghcr.io/huggingface/text-embeddings-inference:cpu-1.7
    restart: always
    # Small batch token budget: we embed page-sized chunks, so the default
    # 16384 is needless and its warmup allocation OOMs on a shared 8 GB host.
    command: ["--model-id", "BAAI/bge-m3", "--auto-truncate", "--max-batch-tokens", "2048"]
    mem_limit: 6g
    environment:
      TZ: ${TZ}
    volumes:
      - "{{ docker_compose_dir }}/library/embedder-cache:/data"

  library-webserver:
    container_name: library-webserver
    image: ghcr.io/johnmathews/library:{{ library_version }}
    restart: always
    ports:
      - "8010:8000"
    env_file: .env
    environment:
      LIBRARY_DATABASE_URL: postgresql+asyncpg://library:${LIBRARY_DB_PASSWORD}@library-db:5432/library
      LIBRARY_DATA_DIR: /data
      LIBRARY_EMBEDDING_SERVICE_URL: http://library-embedder:80
      LIBRARY_ANTHROPIC_API_KEY: "{{ vault_library_anthropic_api_key }}"
    volumes:
      - "/mnt/nfs/document-store/data:/data"
    depends_on:
      library-db:
        condition: service_healthy
      library-migrate:
        condition: service_completed_successfully
      library-embedder:
        condition: service_started
    healthcheck:
      # curl is not in the slim image; the stdlib is.
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/healthz')"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 15s

  library-worker:
    container_name: library-worker
    image: ghcr.io/johnmathews/library:{{ library_version }}
    restart: always
    command: ["python", "-m", "library.worker"]
    env_file: .env
    environment:
      LIBRARY_DATABASE_URL: postgresql+asyncpg://library:${LIBRARY_DB_PASSWORD}@library-db:5432/library
      LIBRARY_DATA_DIR: /data
      LIBRARY_CONSUME_DIR: /consume
      # /consume is its own mount root, so the sibling default for the archive
      # dirs would resolve to the ephemeral container root — pin them to the
      # persistent /data mount (library docs/deployment.md §1.7.2).
      LIBRARY_CONSUMED_DIR: /data/consumed
      LIBRARY_FAILED_DIR: /data/failed
      # The consume dir is an NFS mount; inotify does not cross it.
      LIBRARY_CONSUME_FORCE_POLLING: "true"
      LIBRARY_EMBEDDING_SERVICE_URL: http://library-embedder:80
      LIBRARY_ANTHROPIC_API_KEY: "{{ vault_library_anthropic_api_key }}"
    volumes:
      - "/mnt/nfs/document-store/data:/data"
      - "/mnt/nfs/document-store/consume:/consume"
    depends_on:
      library-db:
        condition: service_healthy
      library-migrate:
        condition: service_completed_successfully
      library-embedder:
        condition: service_started

  node_exporter:
    image: quay.io/prometheus/node-exporter:{{ node_exporter_version }}
    container_name: node_exporter
    command:
      - '--path.rootfs=/host'
      - '--collector.textfile'
      - '--collector.textfile.directory=/textfile'
    ports:
      - "9100:9100"
    # pid: host # not needed if we mount `/:/host` and use `--path.rootfs=/host`
    # network_mode: host # this exposes the default service port (9100) on all interfaces. too broad, we only want it accessible by prom.
    restart: unless-stopped
    volumes:
      - '/:/host:ro,rslave'
      - '/var/lib/node_exporter/textfile_collector:/textfile:ro'

  alloy:
    image: grafana/alloy:{{ alloy_version }}
    container_name: alloy
    restart: unless-stopped
    environment:
      LOKI_WRITE_ENDPOINT: "http://192.168.2.106:3100/loki/api/v1/push"
      NODE_HOSTNAME: "paperless"
      LOG_LEVEL: "warn"
    volumes:
      # config 
      - ./alloy:/etc/alloy:ro
      # docker 
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      # journalctl  
      - /var/log/journal:/var/log/journal:ro
      - /run/log/journal:/run/log/journal:ro
      - /etc/machine-id:/etc/machine-id:ro
    command: >
      run --server.http.listen-addr=0.0.0.0:12345 --stability.level=experimental --storage.path=/var/lib/alloy/data /etc/alloy/config.alloy

    ports:
      - "12345:12345"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:{{ cadvisor_version }}
    container_name: cadvisor
    restart: always
    ports:
      - "18080:8080"
    volumes:
      - /:/rootfs:ro
      - /sys:/sys:ro
      - /sys/fs/cgroup:/sys/fs/cgroup:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /var/run:/var/run:ro
    privileged: false # required for some metrics, but `true` makes it scan /dev/** and in an LXC /dev/series/by-id does not exist.
    security_opt:
      - no-new-privileges:true
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"
