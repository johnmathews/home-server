# vim: ft=jinja2
# Common settings

TZ={{ TZ }}

###############################################################################
# Library settings (github.com/johnmathews/library)                          #
###############################################################################

# Internal docker-network credential for library-db (compose interpolates it).
LIBRARY_DB_PASSWORD={{ vault_library_db_password }}
{% if vault_library_anthropic_api_key is defined %}
# Claude API key for metadata extraction (from ansible vault). When absent,
# documents still OCR and index — extraction is skipped gracefully.
LIBRARY_ANTHROPIC_API_KEY={{ vault_library_anthropic_api_key }}
{% endif %}


LIBRARY_EMAIL_HOST=imap.gmail.com
LIBRARY_EMAIL_USERNAME={{ vault_library_gmail_email_address }}
LIBRARY_EMAIL_PASSWORD={{ vault_library_gmail_app_password }}
LIBRARY_EMAIL_POLL_MINUTES=10


# Public base URL of the web app (no trailing slash). Used to deep-link
# Pushover push notifications back to the document they refer to, so tapping
# a notification opens it in the app. Strongly recommended in production —
# unset = notifications arrive with no link (and the app logs a warning at
# startup). Set it to however you reach the web app from your phone.
LIBRARY_PUBLIC_BASE_URL={{ vault_library_public_base_url }} 
