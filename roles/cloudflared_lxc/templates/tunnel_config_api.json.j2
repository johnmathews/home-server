{# {{ ansible_managed }} #}
{# Cloudflare Tunnel API payload — syncs local config.yml to remote #}
{% set domains = [primary_domain_name] + (migration_additional_domains | default([])) %}
{
  "config": {
    "ingress": [
{% for domain in domains %}
{% for rule in cloudflared_ingress %}
{% set hostname = (rule.prefix + '.' + domain) if rule.prefix else domain %}
{% set origin = {} %}
{% if rule.no_tls_verify | default(false) %}{% set origin = origin | combine({"noTLSVerify": true}) %}{% endif %}
{% if rule.set_host_header | default(false) %}{% set origin = origin | combine({"httpHostHeader": hostname}) %}{% endif %}
      {"hostname": "{{ hostname }}", "originRequest": {{ origin | to_json }}, "service": "{{ rule.service }}"},
{% endfor %}
{% endfor %}
      {"service": "http_status:404", "originRequest": {}}
    ],
    "warp-routing": {"enabled": false}
  }
}
