# vim: ft=yaml
# open_webui_lxc/files/docker-compose.yml.j2

---

services:
  cadvisor:
    image: gcr.io/cadvisor/cadvisor:latest
    container_name: cadvisor
    restart: always
    ports:
      - "18080:8080"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
    privileged: true  # required for some metrics

  alloy:
    image: grafana/alloy:latest
    container_name: alloy
    restart: unless-stopped
    environment:
      LOKI_WRITE_ENDPOINT: "http://192.168.2.106:3100/loki/api/v1/push"
      NODE_HOSTNAME: "open-webui"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./alloy:/etc/alloy:ro 
    command: >
      run --server.http.listen-addr=0.0.0.0:12345
      --storage.path=/var/lib/alloy/data
      /etc/alloy/config.alloy
    ports:
      - "12345:12345"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    container_name: open-webui
    restart: unless-stopped
    ports:
      - "3000:8080"
    environment:
      WEBUI_NAME: "itsa.pizza"
      WEBUI_URL: "https://chat.itsa.pizza"
      ENABLE_SIGNUP: "true"   # let Cloudflare Access be the gate
      ENABLE_SIGNUP_PASSWORD_CONFIRMATION: "true"
      ENABLE_OAUTH: "false"    # set true only if you wire up an OAuth provider
      MAX_FILE_SIZE_MB: "50"
      TZ: ${TZ}
      # Point to OpenAI (default). If using a proxy, set OPENAI_API_BASE.
      OPENAI_API_KEY: ${OPENAI_KEY}
      # Optional: if you use Azure OpenAI or a proxy
      # OPENAI_API_BASE: "https://api.openai.com/v1"
      # OPENAI_API_TYPE: "openai"

    volumes:
      - /srv/apps/open-webui/data:/app/backend/data
      # If you want custom prompts or provider configs:
      # - ./open-webui.json:/app/backend/data/settings.json:ro
