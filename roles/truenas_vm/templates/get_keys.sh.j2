#!/bin/bash
# vim: ft=bash

#/mnt/tank/apps-config/scripts/get_keys.sh

# Unlock and mount encrypted ZFS datasets from a remote key server.
# The key server returns a json string that contains key-value pairs of dataset-key, like
# {
#   "tank/media": {
#     "key": "KEY_FOR_MEDIA",
#     "mountpoint": "/tank/library",
#     "description": "shows and movies"
#   }
# }

# Redirect stdout and stderr to a log file
LOG_FILE="/mnt/tank/apps-config/scripts/get_keys.log"
exec > >(tee -a "$LOG_FILE") 2>&1

echo "────────────────────────────────────────────"
echo "Unlock script started at $(date)"
echo "────────────────────────────────────────────"
echo ""


KEY_SERVER_URL="{{ vault_key_server_url }}"
KEY_SERVER_PORT="{{ vault_key_server_port }}"
KEY_TOKEN="{{ vault_key_server_auth_token }}"
TMP_KEY_FILE_PATH="/tmp/dataset_keys.json"

# Color codes
GREEN="\033[1;32m"
YELLOW="\033[1;33m"
RED="\033[1;31m"
BLUE="\033[1;34m"
CYAN="\033[1;36m"
RESET="\033[0m"

echo -e "${BLUE}[INFO] Fetching dataset keys from key server...${RESET}"
curl -fsSL -H "Authorization: Bearer ${KEY_TOKEN}" "${KEY_SERVER_URL}:${KEY_SERVER_PORT}/unlock" -o "$TMP_KEY_FILE_PATH"

if [ ! -s "$TMP_KEY_FILE_PATH" ]; then
    echo -e "${RED}[ERROR] Failed to fetch key or key is empty${RESET}"
    exit 1
else
    echo -e "${GREEN}  [OK] Keys retrieved${RESET}"
fi

# Ensure jq is available
if ! command -v jq >/dev/null 2>&1; then
    echo -e "${RED}[ERROR] 'jq' is required but not installed${RESET}"
    exit 1
fi

DATASETS=$(jq -r 'keys[]' "$TMP_KEY_FILE_PATH")

for DATASET in $DATASETS; do
    KEY=$(jq -r --arg dataset "$DATASET" '.[$dataset].key' "$TMP_KEY_FILE_PATH")
    DESCRIPTION=$(jq -r --arg dataset "$DATASET" '.[$dataset].description // "no description"' "$TMP_KEY_FILE_PATH")

    echo -e "${BLUE}────────────────────────────────────────────${RESET}"
    echo -e "${BLUE}[DATASET] $DATASET ($DESCRIPTION${RESET})"

    if [ -z "$KEY" ] || [ "$KEY" == "null" ]; then
        echo -e "${YELLOW}[WARN] No key found for $DATASET — skipping${RESET}"
        continue
    fi

    keystatus=$(sudo zfs get -H -o value keystatus "$DATASET")
    if [ "$keystatus" = "available" ]; then
        echo -e "${CYAN}  [OK] Key already loaded${RESET}"
    else
        echo -e "${BLUE}  [ACTION] Loading key...${RESET}"
        echo "$KEY" | sudo zfs load-key -L file:///dev/stdin "$DATASET" && \
        echo -e "${GREEN}    [OK] Key loaded${RESET}" || \
        echo -e "${RED}    [ERROR] Failed to load key for $DATASET${RESET}"
    fi

    mounted=$(sudo zfs get -H -o value mounted "$DATASET")
    if [ "$mounted" = "yes" ]; then
        echo -e "${CYAN}  [OK] Already mounted${RESET}"
    else
        echo -e "${BLUE}  [ACTION] Mounting dataset...${RESET}"
        sudo zfs mount "$DATASET" && \
        echo -e "${GREEN}    [OK] Mounted successfully${RESET}" || \
        echo -e "${RED}    [ERROR] Failed to mount $DATASET${RESET}"
    fi
done

echo -e "${BLUE}────────────────────────────────────────────${RESET}"
echo -e "${BLUE}[CLEANUP] Removing temporary key file...${RESET}"
rm -f "$TMP_KEY_FILE_PATH"
echo -e "${GREEN}  [OK] Done${RESET}"
echo ""
