#!/usr/bin/env bash
# vim: ft=sh

set -euo pipefail

log() { printf '%s mount-touch-probe[%s]: %s\n' "$(date -Is)" "$$" "$*" >&2; }

RO_START="${MTP_RO_START:-22:00}"      # read-only during off-hours
RO_END="${MTP_RO_END:-07:00}"          # off-hours end
PROBE_MODE_DEFAULT="${MTP_MODE:-auto}" # auto|rw|ro

TARGETS_FILE="{{ share_drive_probe_targets_file }}"
TEXTFILE_DIR="{{ share_drive_probe_textfile_dir }}"
STATE_DIR="{{ share_drive_probe_state_dir }}"
METRIC_FILE="${TEXTFILE_DIR}/share_drive_probe.prom"
OP_TIMEOUT="{{ share_drive_probe_op_timeout }}"
HOST="$(hostname)"
EPOCH_NOW="$(date +%s)"

# State constants
STATE_FAIL=0
STATE_SUCCESS=1
STATE_ERROR=-1

# Autofs wake options
AUTOFS_WAKE="{{ share_drive_probe_autofs_wake | default('true') }}"
AUTOFS_POLL_COUNT={{ share_drive_probe_autofs_poll_count | default(30) }}
AUTOFS_POLL_SLEEP_SEC={{ share_drive_probe_autofs_poll_sleep_sec | default('0.1') }}

log "start run: host=$HOST targets_file=$TARGETS_FILE"

# Ensure dirs exist
mkdir -p "$TEXTFILE_DIR" "$STATE_DIR"

# Create temp metrics inside textfile dir; atomic rename at end
tmp_metrics="$(mktemp "{{ share_drive_probe_textfile_dir }}/.share_drive_probe.prom.XXXXXX")"
trap 'rm -f "$tmp_metrics"' EXIT

# Headers
{
  echo "# HELP share_drive_probe_success 1 if probe succeeded, else 0"
  echo "# TYPE share_drive_probe_success gauge"
  echo "# HELP share_drive_probe_duration_seconds Time to probe (s)"
  echo "# TYPE share_drive_probe_duration_seconds gauge"
  echo "# HELP share_drive_probe_last_run_timestamp_seconds UNIX time of last run on this host"
  echo "# TYPE share_drive_probe_last_run_timestamp_seconds gauge"
  echo "# HELP share_drive_probe_state -1=error,0=fail,1=success"
  echo "# TYPE share_drive_probe_state gauge"
  echo "# HELP share_drive_probe_state_change_timestamp_seconds UNIX time of last state change"
  echo "# TYPE share_drive_probe_state_change_timestamp_seconds gauge"
} >> "$tmp_metrics"

any_fail=0

hash_str() {
  if command -v sha256sum >/dev/null 2>&1; then
    echo -n "$1" | sha256sum | awk '{print $1}'
  else
    echo -n "$1" | md5sum | awk '{print $1}'
  fi
}

is_container() {
  if command -v systemd-detect-virt >/dev/null 2>&1; then
    systemd-detect-virt --quiet --container && return 0 || return 1
  fi
  grep -qE '/(lxc|docker|kubepods)/' /proc/1/cgroup 2>/dev/null && return 0 || return 1
}

wake_autofs_if_needed() {
  local p="$1"
  timeout "$OP_TIMEOUT" bash -c "ls -ld \"$p\" >/dev/null 2>&1 || true" || true
  local i
  for ((i=0; i< AUTOFS_POLL_COUNT; i++)); do
    if findmnt -T "$p" >/dev/null 2>&1; then
      return 0
    fi
    sleep "$AUTOFS_POLL_SLEEP_SEC"
  done
  return 1
}

is_now_between() {  # is_now_between HH:MM HH:MM (wraps midnight)
  local start="$1" end="$2" now
  now="$(date +%H:%M)"
  if [[ "$start" < "$end" ]]; then
    [[ "$now" > "$start" && "$now" < "$end" ]]
  else
    [[ "$now" > "$start" || "$now" < "$end" ]]
  fi
}

decide_probe_mode() {
  case "$PROBE_MODE_DEFAULT" in
    rw|ro) echo "$PROBE_MODE_DEFAULT" ;;
    auto)  is_now_between "$RO_START" "$RO_END" && echo "ro" || echo "rw" ;;
  esac
}

probe_ro() {  # metadata-only checks
  local p="$1"
  findmnt -T "$p" >/dev/null 2>&1 || return 2
  timeout "$OP_TIMEOUT" stat -f "$p" >/dev/null 2>&1 || return 3
  timeout "$OP_TIMEOUT" ls -ld "$p" >/dev/null 2>&1 || return 4
  timeout "$OP_TIMEOUT" bash -c 'LC_ALL=C ls -1U "$0" | head -n 1 >/dev/null 2>&1 || true' "$p" || return 5
  return 0
}

while IFS=',' read -r mount_path mount_label; do
  [[ -z "${mount_path// }" ]] && continue
  [[ "${mount_path:0:1}" == "#" ]] && continue

  label="${mount_label:-unknown}"
  safe_key="$(hash_str "${mount_path}_${label}")"
  last_state_file="${STATE_DIR}/${safe_key}.state"

  current_state=$STATE_ERROR
  reason="error"
  mode="unknown"
  dur_s="0"

  # Decide probe mode up-front
  mode="$(decide_probe_mode)"

  # If not mounted and we're in RW mode on a container, try to wake autofs
  if ! findmnt -T "$mount_path" >/dev/null 2>&1; then
    if [[ "$mode" == "rw" && "$AUTOFS_WAKE" == "true" ]] && is_container; then
      log "autofs wake attempt for $mount_path (mode=rw, container)"
      wake_autofs_if_needed "$mount_path" || log "autofs wake timeout: $mount_path"
    fi
  fi

  # Check again
  if ! findmnt -T "$mount_path" >/dev/null 2>&1; then
    current_state=$STATE_FAIL
    reason="fail"
  else
    if [[ "$mode" == "ro" ]]; then
      if probe_ro "$mount_path"; then
        current_state=$STATE_SUCCESS; reason="success"
      else
        current_state=$STATE_FAIL; reason="fail"
      fi
    else
      probe_file="${mount_path}/.probe.$HOST.$EPOCH_NOW.$$.$RANDOM"
      start_ns=$(date +%s%N)
      if timeout "$OP_TIMEOUT" bash -c "umask 077; : > \"$probe_file\"" 2>/dev/null; then
        # (optional) avoid extra churn:
        # (command -v sync >/dev/null && sync -d "$probe_file") >/dev/null 2>&1 || true
        if timeout "$OP_TIMEOUT" rm -f -- "$probe_file" 2>/dev/null; then
          end_ns=$(date +%s%N)
          dur_ns=$((end_ns - start_ns))
          dur_s=$(awk -v ns="$dur_ns" 'BEGIN{printf "%.6f", ns/1e9}')
          current_state=$STATE_SUCCESS; reason="success"
        else
          current_state=$STATE_FAIL; reason="fail"
        fi
      else
        current_state=$STATE_ERROR; reason="error"
      fi
    fi
  fi

  # State-change timestamp (with mode)
  last_state=""
  [[ -f "$last_state_file" ]] && last_state="$(cat "$last_state_file" 2>/dev/null || true)"
  if [[ "$current_state" != "$last_state" ]]; then
    echo "$current_state" > "$last_state_file"
    echo "share_drive_probe_state_change_timestamp_seconds{host=\"$HOST\",mount=\"$mount_path\",label=\"$label\",mode=\"$mode\"} $EPOCH_NOW" >> "$tmp_metrics"
  fi

  # Metrics (single set, with mode)
  echo "share_drive_probe_state{host=\"$HOST\",mount=\"$mount_path\",label=\"$label\",reason=\"$reason\",mode=\"$mode\"} $current_state" >> "$tmp_metrics"
  if [[ "$current_state" -eq $STATE_SUCCESS ]]; then
    echo "share_drive_probe_success{host=\"$HOST\",mount=\"$mount_path\",label=\"$label\",mode=\"$mode\"} 1" >> "$tmp_metrics"
    echo "share_drive_probe_duration_seconds{host=\"$HOST\",mount=\"$mount_path\",label=\"$label\",mode=\"$mode\"} $dur_s" >> "$tmp_metrics"
  else
    echo "share_drive_probe_success{host=\"$HOST\",mount=\"$mount_path\",label=\"$label\",mode=\"$mode\"} 0" >> "$tmp_metrics"
    any_fail=1
  fi

  log "probe mount=$mount_path label=$label mode=$mode state=$current_state reason=$reason"
done < "$TARGETS_FILE"

echo "share_drive_probe_last_run_timestamp_seconds{host=\"$HOST\"} $EPOCH_NOW" >> "$tmp_metrics"
chown root:root "$tmp_metrics"
chmod 0644 "$tmp_metrics"
mv -f "$tmp_metrics" "$METRIC_FILE"
log "wrote metrics to $METRIC_FILE"
trap - EXIT
exit "$any_fail"
