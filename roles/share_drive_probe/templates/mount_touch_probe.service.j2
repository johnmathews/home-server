# vim: ft=systemd

[Unit]
Description=Mount Touch Probe (SMB/NFS liveness)
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/timeout 85s {{ mount_touch_probe_bin }}
TimeoutStartSec=90s
User=root
Group=root
UMask=0022
Nice=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mount-touch-probe

# Optional hardening:
# ProtectSystem=strict
# ReadWritePaths={{ mount_touch_probe_textfile_dir }} {{ mount_touch_probe_state_dir }} {{ mount_touch_probe_conf_dir }}

Environment=MTP_MODE=auto
Environment=MTP_RO_START={{ mount_touch_probe_dont_spin_up_start }}
Environment=MTP_RO_END={{ mount_touch_probe_dont_spin_up_end }}
