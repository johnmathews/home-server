# NFS/SMB Shares to Control
# Generated by Ansible - do not edit manually
# One share per line

{# If sleep_hours_nfs_shares is defined, use it; otherwise derive from nfs_shares and smb_shares #}
{% set shares_to_control = sleep_hours_nfs_shares | default([]) %}
{% if shares_to_control | length == 0 %}
  {# Extract target paths from nfs_shares #}
  {% if nfs_shares is defined %}
    {% set shares_to_control = nfs_shares | map(attribute='target') | list %}
  {% else %}
    {% set shares_to_control = [] %}
  {% endif %}
  {# Also add target paths from smb_shares #}
  {% if smb_shares is defined %}
    {% set smb_targets = smb_shares | map(attribute='target') | list %}
    {% set shares_to_control = shares_to_control + smb_targets %}
  {% endif %}
{% endif %}

{% for share in shares_to_control %}
{{ share }}
{% endfor %}
