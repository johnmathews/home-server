# NFS/SMB Shares to Control
# Generated by Ansible - do not edit manually
# One share per line

{# Derive shares from nfs_shares and smb_shares target paths #}
{% set shares_to_control = nfs_shares | default([]) | map(attribute='target') | list %}
{% if smb_shares is defined %}
{% set shares_to_control = shares_to_control + (smb_shares | map(attribute='target') | list) %}
{% endif %}
{% for share in shares_to_control %}
{{ share }}
{% endfor %}
