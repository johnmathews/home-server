# NFS/SMB Shares to Control
# Generated by Ansible - do not edit manually
# One share per line

{# If sleep_hours_nfs_shares is defined, use it; otherwise derive from nfs_shares #}
{% set shares_to_control = sleep_hours_nfs_shares | default([]) %}
{% if shares_to_control | length == 0 and nfs_shares is defined %}
  {# Extract target paths from nfs_shares list #}
  {% set shares_to_control = nfs_shares | map(attribute='target') | list %}
{% endif %}

{% for share in shares_to_control %}
{{ share }}
{% endfor %}
