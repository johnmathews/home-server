# vim: ft=bash

# OpenClaw environment variables

TZ={{ TZ }}

# Gateway token (set after running: docker compose run --rm openclaw-cli onboard --no-install-daemon)
OPENCLAW_GATEWAY_TOKEN={{ vault_openclaw_gateway_token | default('') }}

# LLM provider API keys (leave blank if using subscription auth instead)
ANTHROPIC_API_KEY={{ vault_anthropic_api_key | default('') }}
OPENAI_API_KEY={{ vault_openai_api_key | default('') }}

# Paths
OPENCLAW_CONFIG_DIR=/srv/apps/openclaw/config
OPENCLAW_WORKSPACE_DIR=/srv/apps/openclaw/workspace

# Network
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# Image
OPENCLAW_IMAGE=openclaw:local
