# vim: ft=sh

ATUIN_DB_NAME=atuin
ATUIN_DB_USERNAME=atuin
ATUIN_DB_PASSWORD={{ vault_atuin_db_password }}

PORTAINER_TOKEN={{ vault_portainer_container_metrics_exporter_key }}

PORTAINER_AGENT_SECRET={{ vault_portainer_agent_secret }}

GITHUB_TOKEN={{ vault_github_pat_token }}
ANTHROPIC_API_KEY_UNIFIED_DOCUMENTATION_SERVER={{ vault_anthropic_api_key_unified_documentation_server }}

ANTHROPIC_API_KEY_SRE_AGENT={{ vault_anthropic_sre_agent_api_key }}

############ SRE AGENT ##############################

USER_TIMEZONE=Europe/Amsterdam
REQUEST_TIMEOUT_SECONDS=120

DOCUMENTATION_MCP_URL=http://192.168.2.106:8085/mcp

# Report schedule (optional — leave empty to disable scheduled reports)
# Cron expression: minute hour day-of-month month day-of-week
REPORT_SCHEDULE_CRON=0 20 * * 1
REPORT_LOOKBACK_DAYS=7

# Conversation history persistence (optional — leave empty to disable)
# When set, full conversation data (including tool calls) is saved as JSON files
CONVERSATION_HISTORY_HOST_DIR="/srv/infra/sre-agent"

# TrueNAS SCALE API (optional — leave empty to disable TrueNAS tools)
TRUENAS_URL={{ vault_truenas_url }}
TRUENAS_API_KEY={{ vault_truenas_api_key }}
TRUENAS_VERIFY_SSL=false
TRUENAS_CA_CERT=

# SMTP / Email (optional — leave empty to disable email delivery of reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME={{ vault_sre_agent_email_address }}
SMTP_PASSWORD={{ vault_sre_agent_email_sre_agent_app_password }}
REPORT_RECIPIENT_EMAIL={{ vault_sre_agent_recipient_email_address }}

# LLM Provider: "openai" (default) or "anthropic"
# When using anthropic, set ANTHROPIC_API_KEY (from `claude setup-token`)
# When using openai, set OPENAI_API_KEY
LLM_PROVIDER=anthropic

# OpenAI
OPENAI_API_KEY={{ vault_openai_api_key }}
OPENAI_MODEL=gpt-4o
OPENAI_SA_NAME=homelab-sre-agent
OPENAI_SA_API_KEY={{ vault_openai_sa_api_key }}

# OpenAI-compatible proxy (optional — leave empty to use OpenAI directly)
# For claude-max-api-proxy: http://localhost:3456/v1
# When using a proxy, OPENAI_API_KEY can be set to any placeholder value
OPENAI_BASE_URL=

# Anthropic API (optional — only needed when LLM_PROVIDER=anthropic)
# Generate token: `claude setup-token` (requires Claude Max/Pro subscription)
ANTHROPIC_CLAUDE_SETUP_TOKEN={{ vault_anthropic_claude_setup_token }}

ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Prometheus
PROMETHEUS_URL={{ vault_prometheus_url }}

# Grafana (alerting)
GRAFANA_URL={{ vault_grafana_url }}
GRAFANA_SERVICE_ACCOUNT_USER=SRE_agent
GRAFANA_SERVICE_ACCOUNT_TOKEN={{ vault_grafana_service_account_token }}
GRAFANA_SERVICE_ACCOUNT_TOKEN_NAME={{ vault_grafana_service_account_token_name }}

# Proxmox VE API (optional)
PROXMOX_URL={{ vault_proxmox_url }}
PROXMOX_API_TOKEN={{ vault_proxmox_api_token }}
PROXMOX_VERIFY_SSL=false
PROXMOX_CA_CERT=
PROXMOX_NODE=proxmox

# Proxmox Backup Server API (optional — leave empty to disable PBS tools)
PBS_URL={{ vault_pbs_url }}
PBS_API_TOKEN={{ vault_pbs_api_token }}
PBS_VERIFY_SSL=false
PBS_CA_CERT=
PBS_NODE=proxmox-backup-server
PBS_DEFAULT_DATASTORE=pbs

# Extra document directories for RAG ingestion (comma-separated absolute paths)
# These directories are read-only — only .md files are loaded for embeddings
EXTRA_DOCS_DIRS=

# Loki API (optional — leave empty to disable Loki log tools)
LOKI_URL={{ vault_loki_url }}

# Streamlit UI — URL of the FastAPI backend
# Change to http://api:8000 when running in Docker
API_URL=http://localhost:8000
