# vim: ft=yaml

sources:
  - name: "SRE-agent"
    path: "https://github.com/johnmathews/sre-agent.git"
    branch: "main"
  - name: "SRE-webapp"
    path: "https://github.com/johnmathews/sre-webapp.git"
    branch: "main"
  - name: "home-server"
    path: "https://${GITHUB_TOKEN}@github.com/johnmathews/home-server.git"
    branch: "main"
  - name: "unified-documentation-server"
    path: "https://github.com/johnmathews/unified-documentation-server"
    branch: "main"
  - name: "unified-documentation-web-app"
    path: "https://github.com/johnmathews/unified-documentation-webapp"
    branch: "main"
  - name: "journal-insights-agent"
    path: "https://github.com/johnmathews/journal-agent"
    branch: "main"
  - name: "nanoclaw-personal-ai-assistant"
    path: "https://github.com/johnmathews/nanoclaw"
    branch: "main"
  - name: "timer-app"
    path: "https://github.com/johnmathews/gym-timer"
    branch: "main"
  - name: "disk-status-exporter"
    path: "https://github.com/johnmathews/disk_status_exporter"
    branch: "main"
  - name: "container-status-exporter"
    path: "https://github.com/johnmathews/container-status-exporter"
    branch: "main"
  - name: "Document Stream (k8s)"
    path: "https://github.com/johnmathews/DocumentStream"
    branch: "main"
    patterns:
      - "**/*.pdf"
      - "**/*.md"
      - "docs/**/*.md"
      - "journal/**/*.md"
      - ".engineering-team/**/*.md"
      - "CLAUDE.md"
      - "README.md"

poll_interval: 30 # Seconds between index cycles
data_dir: "/data" # Persistent storage path
