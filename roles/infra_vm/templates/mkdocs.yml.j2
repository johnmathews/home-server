site_name: Home Server Documentation

theme:
  name: material
  features:
    - navigation.instant
    - navigation.tracking
    - content.code.copy

markdown_extensions:
  - admonition
  - toc:
      permalink: true
  - tables

plugins:
  - search

nav:
  - Home: readme.md
  - UPS: ups.md
  - Key Server: key_server.md
  - Adguard + Unbound: adguard-unbound.md
  - Cloudflared: cloudflared.md
  - HDDs: disks.md
  - iperf3-speedtest: iperf3-speedtest.md
  - media_vm + qbittorrent: media_vm_qbittorrent.md
  - TrueNAS: truenas.md
  - NFS: nfs.md
