# Images watched by Diun; a Pushover notification is sent when a watched tag's
# digest changes upstream (notify_on defaults to new;update).
#
# Excluded on purpose:
#   - ghcr.io/johnmathews/* (self-built - they change when you push, no news there)
#   - database images (postgres, mariadb, valkey, redis-stack, elasticsearch) -
#     version moves there deserve a migration plan, not a nudge
#   - fully pinned images (loki, homepage, dozzle, uptime-kuma, tubearchivist,
#     sabnzbd, flaresolverr, portainer-agent, mkdocs, chroma...) - bump the pin
#     in the role defaults when you choose to upgrade
#
# NOTE: linuxserver.io images rebuild weekly even without app changes, so the
# media block below will produce regular notifications. Trim it if too chatty.

# --- primary apps ---
- name: docker.io/jellyfin/jellyfin:latest
- name: ghcr.io/immich-app/immich-server:release
- name: ghcr.io/immich-app/immich-machine-learning:release
- name: docker.io/alangrainger/immich-public-proxy:latest
- name: ghcr.io/open-webui/open-webui:main
- name: docker.io/deluan/navidrome:latest

# --- media stack (media-vm; linuxserver images rebuild weekly - see note) ---
- name: docker.io/linuxserver/sonarr:latest
- name: docker.io/linuxserver/radarr:latest
- name: docker.io/linuxserver/qbittorrent:latest
- name: docker.io/linuxserver/bazarr:latest
- name: lscr.io/linuxserver/prowlarr:latest
- name: docker.io/qmcgaw/gluetun:latest
- name: docker.io/slskd/slskd:latest
- name: docker.io/fallenbagel/jellyseerr:latest
- name: ghcr.io/booklore-app/booklore:latest

# --- music extras ---
- name: ghcr.io/jeffvli/feishin:latest
- name: docker.io/jlesage/musicbrainz-picard:latest

# --- infra / monitoring ---
- name: docker.io/grafana/grafana-oss:latest
- name: docker.io/prom/prometheus:latest
- name: docker.io/portainer/portainer-ce:latest
- name: ghcr.io/akpw/mktxp:latest
- name: docker.io/traefik:v3.1
- name: docker.io/crazymax/diun:latest

# --- monitoring sidecars on the latest-tracking hosts (agent, music,
#     prometheus, traefik, document_library); pinned hosts use sidecar_* ---
- name: docker.io/grafana/alloy:latest
- name: quay.io/prometheus/node-exporter:latest
- name: docker.io/prom/node-exporter:latest
- name: gcr.io/cadvisor/cadvisor:latest

