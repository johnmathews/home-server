# vim: ft=yaml
# prometheus.yml.j2

---

global:
  scrape_interval: 15s  # default interval for scraping targets

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'cadvisor'
    static_configs:
      - targets: ['cadvisor:8080']

  - job_name: 'home-assistant'
    metrics_path: /api/prometheus
    scheme: http
    authorization:
      type: Bearer
      credentials: "{{ vault_home_assistant_token }}"
    static_configs:
      - targets: ['192.168.2.102:8123']

  - job_name: 'unbound'
    static_configs:
      - targets: ['192.168.2.111:9167']

  - job_name: 'proxmox-ipmi'
    metrics_path: /metrics
    static_configs:
      - targets: ['192.168.2.214:9290']
        labels:
          instance: proxmox

  - job_name: 'proxmox-host-node-exporter'
    static_configs:
      - targets: ['192.168.2.214:9100']

  - job_name: 'proxmox-smartctl'
    static_configs:
      - targets: ['192.168.2.214:9633']

  - job_name: 'pve-exporter'
    metrics_path: /pve
    params:
      module: [default]
      cluster: ['1']
      node: ['1']
    static_configs:
      - targets: ['192.168.2.214:9221']

  - job_name: 'pve-exporter-internal'
    static_configs:
      - targets: ['192.168.2.214:9221']

  - job_name: 'truenas-node-exporter'
    static_configs:
      - targets: ['192.168.2.104:9100']

  - job_name: 'truenas-smrtctl-exporter'
    static_configs:
      - targets: ['192.168.2.104:9100']

  - job_name: 'proxmox-textfile'
    metrics_path: /metrics
    static_configs:
      - targets: ['192.168.2.214:9100']
    relabel_configs:
      - source_labels: [__name__]
        regex: 'radeontop_.*'
        action: keep
