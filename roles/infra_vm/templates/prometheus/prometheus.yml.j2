# vim: ft=yaml
# prometheus.yml
---

global:
  scrape_interval: 15s  # default interval for scraping targets

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node-exporter'
    static_configs:
      - targets: ['node-exporter:9100']

  - job_name: 'cadvisor'
    static_configs:
      - targets: ['cadvisor:8080']

  - job_name: 'home_assistant'
    metrics_path: /api/prometheus
    scheme: http
    authorization:
      type: Bearer
      credentials: "{{ vault_home_assistant_token }}"
    static_configs:
      - targets: ['192.168.2.102:8123']

  - job_name: 'unbound'
    static_configs:
      - targets: ['192.168.2.111:9167']

  - job_name: 'proxmos-ipmi'
    metrics_path: /metrics
    static_configs:
      - targets: ['192.168.2.214:9290']
        labels:
          instance: proxmox

  - job_name: 'proxmos-node'
    static_configs:
      - targets: ['192.168.2.214:9100']

  - job_name: 'smartctl'
    static_configs:
      - targets: ['192.168.2.214:9633']
