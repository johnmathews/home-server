# vim: ft=yaml
# infra_vm/templates/docker-compose.yml

services:

  documentation-webapp:
    image: ghcr.io/johnmathews/unified-documentation-webapp:{{ documentation_ui_version }}
    container_name: documentation-webapp
    restart: unless-stopped
    # Stateless SvelteKit proxy. Steady state ~50 MB; bounded per-request
    # buffer of one downloaded file (max 5 MB) for inline rendering.
    mem_limit: 192m
    mem_reservation: 64m
    ports:
      - "3003:3000"
    environment:
      - API_URL=http://documentation-server:8080
    depends_on:
      - documentation-server
    logging:
      driver: json-file
      options:
        max-size: "5m"
        max-file: "3"

  documentation-server:
    image: ghcr.io/johnmathews/unified-documentation-server:latest
    container_name: documentation-server
    restart: unless-stopped
    stop_grace_period: 30s
    init: true
    depends_on:
      documentation-chroma:
        condition: service_healthy
    # Memory budget on a 1.95 GB host (infra VM) sharing RAM with the
    # observability stack (Loki, Grafana, Alloy, exporters). 768 MB caps
    # the container BELOW the VM's available memory so the cgroup OOM can
    # actually fire — the kernel's OOM killer will pick the highest-RSS
    # process in the cgroup (the embedding worker subprocess) cleanly,
    # rather than falling through to a global OOM that degrades the host.
    # Do NOT raise without raising the VM's available RAM.
    mem_limit: 1024m
    mem_reservation: 512m
    # Mark this container as the preferred OOM victim on the host so any
    # global memory pressure kills the embedding subprocess before
    # touching the observability stack (which has oom_score_adj: -500).
    oom_score_adj: 500
    ports:
      - "8085:8080"
    volumes:
      # Persistent data (SQLite + git clones + cached ONNX model). Chroma
      # vectors live in the chroma-data volume mounted on the chroma
      # service above.
      - docserver-data:/data
      - ./docserver/config/sources.yaml:/config/sources.yaml:ro
    environment:
      # 30-minute polling. Each cycle spawns a worker subprocess that
      # loads the ONNX embedding model (~110 MB on disk, ~1+ GB resident
      # for a real-content cycle on large sources) and exits — RSS is
      # released back to the OS. Going below 1800 multiplies the chance
      # of a real-content cycle landing during peak memory of co-tenants.
      - DOCSERVER_POLL_INTERVAL=1800
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY_UNIFIED_DOCUMENTATION_SERVER}
      - GITHUB_TOKEN=${GITHUB_TOKEN}
      - DOCSERVER_CHAT_MODEL=claude-opus-4-7
      - DOCSERVER_CHROMA_HOST=documentation-chroma
      - DOCSERVER_CHROMA_PORT=8000
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  documentation-chroma:
    image: chromadb/chroma:1.5.8
    container_name: documentation-chroma
    restart: unless-stopped
    command: ["run", "--path", "/chroma-data", "--host", "0.0.0.0", "--port", "8000"]
    volumes:
      - documentation-chroma-data:/chroma-data
    expose:
      - "8000"
    mem_limit: 256m
    mem_reservation: 100m
    healthcheck:
      test: ["CMD", "/bin/bash", "-c", "</dev/tcp/127.0.0.1/8000"]
      interval: 10s
      timeout: 5s
      start_period: 30s
      retries: 3
    logging:
      driver: json-file
      options:
        max-size: "5m"
        max-file: "3"

  timer:
    image: ghcr.io/johnmathews/gym-timer:{{ gym_timer_version }}
    container_name: timer
    volumes:
      - ./timer/:/config
    ports:
      - "8082:80"
    restart: unless-stopped

  sre-ingest:
    image: ghcr.io/johnmathews/sre-agent:{{ sre_assistant_version }}
    container_name: sre-ingest
    command: ["python", "-m", "scripts.ingest_runbooks"]
    user: 1001:1001
    environment:
      - ANONYMIZED_TELEMETRY=False
    env_file: .env
    volumes:
      - chroma_data:/app/.chroma_db
    profiles: ["setup"]

  sre-agent:
    image: ghcr.io/johnmathews/sre-agent:{{ sre_assistant_version }}
    container_name: sre-agent
    user: "1001:1001"
    ports:
      - "8001:8000"
    restart: unless-stopped
    mem_limit: 768m
    env_file: .env # gets all the env vars in the file automatically
    environment:
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY_SRE_AGENT}
      - ANONYMIZED_TELEMETRY=False
      - CLAUDE_CONFIG_DIR=/app/.claude
      - HOME=/app
      - DOCUMENTATION_MCP_URL=${DOCUMENTATION_MCP_URL}
    volumes:
      - chroma_data:/app/.chroma_db
      - ${CONVERSATION_HISTORY_HOST_DIR}:/app/conversations
      # Claude Agent SDK: OAuth credentials for LLM_PROVIDER=anthropic.
      # Harmless empty-dir mount when using LLM_PROVIDER=openai.
      - ${CLAUDE_CONFIG_DIR:-~/.claude}:/app/.claude
      # Uncomment to persist the memory store SQLite DB:
      - ./sre-memory.db:/app/memory.db
    healthcheck:
      test: ["CMD", "python", "-c", "import httpx; httpx.get('http://localhost:8000/health').raise_for_status()"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

  sre-webapp:
    image: ghcr.io/johnmathews/sre-webapp:latest
    container_name: sre-webapp
    ports:
      - "8501:80"
    restart: unless-stopped
    environment:
      - API_UPSTREAM=http://sre-agent:8000
    mem_limit: 64m
    depends_on:
      sre-agent:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost/"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

  loki:
    image: grafana/loki:{{ loki_version }}
    container_name: loki
    command: ["-config.file=/etc/loki/config.yml"]
    ports:
      - "3100:3100"
    user: "0:0" # writes to local volume
    mem_limit: 200m # ADDED: currently ~125MB
    # Observability backstop: protect from the host OOM killer so a
    # docserver memory spike cannot blind us to the rest of the homelab.
    oom_score_adj: -500
    volumes:
      - ./loki/config.yml:/etc/loki/config.yml
      - ./loki/data:/loki # local storage
    restart: unless-stopped

  alloy:
    image: grafana/alloy:{{ alloy_version }}
    container_name: alloy
    restart: unless-stopped
    mem_limit: 128m # ADDED: currently ~82MB
    oom_score_adj: -500 # Observability backstop, see loki above.
    environment:
      LOKI_WRITE_ENDPOINT: "http://192.168.2.106:3100/loki/api/v1/push"
      NODE_HOSTNAME: "infra"
      LOG_LEVEL: "warn"
    volumes:
      # config 
      - ./alloy:/etc/alloy:ro
      # docker 
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      # journalctl  
      - /var/log/journal:/var/log/journal:ro
      - /run/log/journal:/run/log/journal:ro
      - /etc/machine-id:/etc/machine-id:ro
    command: >
      run --server.http.listen-addr=0.0.0.0:12345 --stability.level=experimental --storage.path=/var/lib/alloy/data /etc/alloy/config.alloy
    ports:
      - "12345:12345"
      - "1514:1514/udp"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  mkdocs:
    image: squidfunk/mkdocs-material:{{ mkdocs_material_version }}
    container_name: mkdocs
    working_dir: /docs
    volumes:
      - ./mkdocs/docs:/docs/docs:rw
      - ./mkdocs/mkdocs.yml:/docs/mkdocs.yml:ro
    ports:
      - "8000:8000"
    restart: unless-stopped

  iperf3:
    image: networkstatic/iperf3
    container_name: iperf3
    restart: unless-stopped
    command: -s
    ports:
      - "5201:5201" # TCP
      - "5201:5201/udp" # UDP

  homepage:
    image: ghcr.io/gethomepage/homepage:{{ homepage_version }}
    container_name: homepage
    mem_limit: 192m
    environment:
      PUID: 1000
      PGID: 1000
      HOMEPAGE_ALLOWED_HOSTS: "192.168.2.106:3002,{{ primary_domain_name }}"
    ports:
      - 3002:3000
    env_file:
      - /srv/infra/homepage/config/.env
    volumes:
      - /srv/infra/homepage/config:/app/config
      - /var/run/docker.sock:/var/run/docker.sock:ro
    restart: always

  grafana:
    image: grafana/grafana-oss:{{ grafana_version }}
    container_name: grafana
    mem_limit: 256m # ADDED: currently ~183MB, biggest consumer
    oom_score_adj: -500 # Observability backstop, see loki above.
    environment:
      TZ: Europe/Amsterdam # alert notification templates render .StartsAt.Local
    ports:
      - "3000:3000"
    volumes:
      - /srv/infra/grafana/data:/var/lib/grafana
      - /srv/infra/grafana/grafana.ini:/etc/grafana/grafana.ini
    restart: always

  node-exporter:
    image: prom/node-exporter:{{ node_exporter_version }}
    container_name: node-exporter
    restart: always
    oom_score_adj: -500 # Observability backstop, see loki above.
    ports:
      - "9100:9100"
    pid: "host"
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - '--path.procfs=/host/proc'
      - '--path.sysfs=/host/sys'
      - '--path.rootfs=/rootfs'
      - '--collector.filesystem.ignored-mount-points=^/(sys|proc|dev|host|etc)($|/)'

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:{{ cadvisor_version }}
    container_name: cadvisor
    restart: unless-stopped
    mem_limit: 96m # ADDED: currently ~45MB
    oom_score_adj: -500 # Observability backstop, see loki above.
    ports:
      - "8080:8080"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /sys/fs/cgroup:/sys/fs/cgroup:ro
      - /var/lib/docker:/var/lib/docker:ro
      - /var/lib/containerd:/var/lib/containerd:ro
    read_only: true
    tmpfs:
      - /tmp
    security_opt:
      - no-new-privileges:true
    command:
      - '--housekeeping_interval=30s'
      - '--docker_only=true'
      - '--disable_metrics=tcp,udp,sched,process,hugetlb'
      - '--store_container_labels=true'

  uptime-kuma:
    image: louislam/uptime-kuma:{{ uptime_kuma_version }}
    container_name: uptime-kuma
    mem_limit: 192m # ADDED: currently ~142MB
    ports:
      - "3001:3001"
    environment:
      - UPTIME_KUMA_DISABLE_FRAME_SAMEORIGIN=true
    volumes:
      - /srv/infra/uptime_kuma/data:/app/data
    restart: always

  dozzle:
    image: amir20/dozzle:{{ dozzle_version }}
    container_name: dozzle
    ports:
      - "9999:8080"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    restart: always

  portainer:
    image: portainer/portainer-ce
    container_name: portainer
    environment:
      # Must match AGENT_SECRET on every portainer-agent (vault_portainer_agent_secret)
      - AGENT_SECRET=${PORTAINER_AGENT_SECRET}
    ports:
      - "9000:9000"
    volumes:
      - /srv/infra/portainer/data:/data
      - /var/run/docker.sock:/var/run/docker.sock
    restart: always

  mikrotik_exporter:
    image: ghcr.io/akpw/mktxp:{{ mktxp_version }}
    container_name: mikrotik_exporter
    user: "1001:1001"
    command: mktxp --cfg-dir /etc/mktxp export
    ports:
      - "49090:49090"
    volumes:
      - /srv/infra/mikrotik_exporter:/etc/mktxp
    restart: always

  container-health-exporter:
    image: ghcr.io/johnmathews/container-status-exporter:{{ container_status_exporter_version }}
    container_name: container-status-exporter
    ports:
      - "8081:8081"
    environment:
      PORTAINER_URL: "http://192.168.2.106:9000"
      PORTAINER_TOKEN: "${PORTAINER_TOKEN}"
      SCRAPE_INTERVAL: "30"
      LISTEN_PORT: "8081"
      LOG_LEVEL: "INFO"
    restart: unless-stopped

  atuin:
    restart: always
    container_name: atuin
    image: ghcr.io/atuinsh/atuin:{{ atuin_version }}
    command: start
    volumes:
      - "/srv/infra/atuin:/config"
    ports:
      - 8888:8888
    environment:
      ATUIN_HOST: "0.0.0.0"
      ATUIN_OPEN_REGISTRATION: "true"
      ATUIN_DB_URI: postgres://$ATUIN_DB_USERNAME:$ATUIN_DB_PASSWORD@atuin-db/$ATUIN_DB_NAME
      RUST_LOG: info,atuin_server=debug
    depends_on:
      atuin-db:
        condition: service_healthy
  atuin-db:
    image: postgres:14
    container_name: atuin_database
    restart: unless-stopped
    volumes: # Don't remove permanent storage for index database files!
      - "/srv/infra/atuin/database:/var/lib/postgresql/data/"
    environment:
      POSTGRES_USER: ${ATUIN_DB_USERNAME}
      POSTGRES_PASSWORD: ${ATUIN_DB_PASSWORD}
      POSTGRES_DB: ${ATUIN_DB_NAME}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $ATUIN_DB_USERNAME -d $ATUIN_DB_NAME"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s


volumes:
  chroma_data:
  docserver-data:
  documentation-chroma-data:
