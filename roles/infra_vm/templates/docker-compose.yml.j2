  loki:
    image: grafana/loki:latest
    container_name: loki
    command: ["-config.file=/etc/loki/config.yml"]
    ports:
      - "3100:3100"
    user: "0:0" # writes to local volume
    volumes:
      - ./loki/config.yml:/etc/loki/config.yml
      - ./loki/data:/loki # local storage
    restart: unless-stopped

  alloy:
    image: grafana/alloy:latest
    container_name: alloy
    restart: unless-stopped
    environment:
      LOKI_WRITE_ENDPOINT: "http://192.168.2.106:3100/loki/api/v1/push"
      NODE_HOSTNAME: "infra"
      LOG_LEVEL: "warn"
    volumes:
      # config 
      - ./alloy:/etc/alloy:ro
      # docker 
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      # journalctl  
      - /var/log/journal:/var/log/journal:ro
      - /run/log/journal:/run/log/journal:ro
      - /etc/machine-id:/etc/machine-id:ro
    command: >
      run --server.http.listen-addr=0.0.0.0:12345 --storage.path=/var/lib/alloy/data /etc/alloy/config.alloy
    ports:
      - "12345:12345"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  mkdocs:
    image: squidfunk/mkdocs-material:latest
    container_name: mkdocs
    working_dir: /docs
    volumes:
      - ./mkdocs/docs:/docs/docs:rw
      - ./mkdocs/mkdocs.yml:/docs/mkdocs.yml:ro
    ports:
      - "8000:8000"
    restart: unless-stopped

  iperf3:
    image: networkstatic/iperf3
    container_name: iperf3
    restart: unless-stopped
    command: -s
    ports:
      - "5201:5201" # TCP
      - "5201:5201/udp" # UDP

  # filebrowser:
  #   image: filebrowser/filebrowser:latest
  #   container_name: filebrowser
  #   user: "1000:1000"
  #   ports:
  #     - "8082:80"
  #   volumes:
  #     - /mnt/nfs:/srv
  #     - /srv/infra/filebrowser/config:/config
  #     - /srv/infra/filebrowser/config/database:/database
