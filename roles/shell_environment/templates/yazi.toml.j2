# Yazi configuration for {{ ansible_hostname }}
# Managed by Ansible - shell_environment role
# User: {{ item.split(':')[0] }}

[manager]
# Show hidden files by default
show_hidden = true

[preview]
# Image preview settings optimized for kitty terminal over SSH
# Use sixel for better tmux compatibility
image_filter = "lanczos3"
image_quality = 90
max_width = 600
max_height = 900
