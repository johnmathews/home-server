# vim: ft=zsh

# Powerlevel10k configuration for {{ ansible_hostname }}
# Managed by Ansible - shell_environment role

# Instant prompt mode
typeset -g POWERLEVEL9K_INSTANT_PROMPT=verbose

# Character set
typeset -g POWERLEVEL9K_MODE=nerdfont-complete

# Transient prompt (clean up previous prompts)
typeset -g POWERLEVEL9K_TRANSIENT_PROMPT=always

# Left prompt segments
typeset -g POWERLEVEL9K_LEFT_PROMPT_ELEMENTS=(
  context                 # user@hostname
  dir                     # current directory
  vcs                     # git status
  newline                 # newline
  prompt_char             # prompt symbol
)

# Right prompt segments
typeset -g POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS=(
  status                  # exit code
  command_execution_time  # duration
  background_jobs         # background jobs indicator
  direnv                  # direnv status
  virtualenv              # python virtualenv
  anaconda                # conda environment
  pyenv                   # pyenv
  nodeenv                 # node.js version
  nvm                     # nvm
  nodenv                  # nodenv
  kubecontext             # kubernetes context
  terraform               # terraform workspace
  time                    # current time
)

# Dracula color scheme for better contrast
# Background: 236 (#282a36)
# Foreground: 255 (#f8f8f2)
# Cyan: 117 (#8be9fd)
# Green: 84 (#50fa7b)
# Orange: 215 (#ffb86c)
# Pink: 212 (#ff79c6)
# Purple: 141 (#bd93f9)
# Red: 203 (#ff5555)
# Yellow: 228 (#f1fa8c)

# Context (user@host) settings
typeset -g POWERLEVEL9K_CONTEXT_TEMPLATE='%n@%m'
typeset -g POWERLEVEL9K_ALWAYS_SHOW_CONTEXT=true
typeset -g POWERLEVEL9K_CONTEXT_PREFIX=''
typeset -g POWERLEVEL9K_CONTEXT_FOREGROUND=117  # Dracula cyan
typeset -g POWERLEVEL9K_CONTEXT_BACKGROUND=236  # Dracula background

# Directory settings
typeset -g POWERLEVEL9K_DIR_FOREGROUND=141      # Dracula purple
typeset -g POWERLEVEL9K_DIR_BACKGROUND=236      # Dracula background
typeset -g POWERLEVEL9K_SHORTEN_STRATEGY=truncate_to_unique
typeset -g POWERLEVEL9K_SHORTEN_DIR_LENGTH=1

# VCS (git) settings
typeset -g POWERLEVEL9K_VCS_CLEAN_FOREGROUND=84      # Dracula green
typeset -g POWERLEVEL9K_VCS_UNTRACKED_FOREGROUND=117 # Dracula cyan
typeset -g POWERLEVEL9K_VCS_MODIFIED_FOREGROUND=228  # Dracula yellow
typeset -g POWERLEVEL9K_VCS_BACKGROUND=236           # Dracula background

# Status settings
typeset -g POWERLEVEL9K_STATUS_OK=false
typeset -g POWERLEVEL9K_STATUS_ERROR=true

# Command execution time settings
typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_THRESHOLD=3
typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_PRECISION=0

# Time format
{% raw %}
typeset -g POWERLEVEL9K_TIME_FORMAT='%D{%H:%M:%S}'

# Prompt character (Dracula colors)
typeset -g POWERLEVEL9K_PROMPT_CHAR_OK_{VIINS,VICMD,VIVIS,VIOWR}_FOREGROUND=84   # Dracula green
typeset -g POWERLEVEL9K_PROMPT_CHAR_ERROR_{VIINS,VICMD,VIVIS,VIOWR}_FOREGROUND=203  # Dracula red
{% endraw %}
