# vim: ft=zsh

# Zsh configuration for {{ ansible_hostname }}
# Managed by Ansible - shell_environment role
# User: {{ item.split(':')[0] }}

# Enable Powerlevel10k instant prompt (must be near the top)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Oh My Zsh configuration
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins
plugins=(
{% for plugin in shell_environment_omz_plugins %}
  {{ plugin }}
{% endfor %}
)

source $ZSH/oh-my-zsh.sh

# Load Powerlevel10k config
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# NOTE: TERM_PROGRAM is intentionally NOT set here
# Kitty graphics protocol doesn't work through SSH + tmux

# Load shell aliases
[[ -f ~/.zsh_aliases ]] && source ~/.zsh_aliases

# User preferences
export EDITOR=nvim
export VISUAL=nvim
export PAGER=less

# History configuration
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS

{% if shell_environment_vim_mode_enabled | bool %}
# Vi mode configuration
bindkey -v
export KEYTIMEOUT=10

# Use 'kj' to enter normal mode (alternative to ESC)
bindkey -M viins 'kj' vi-cmd-mode

# Change cursor shape for different vi modes (beam for insert, block for normal)
function zle-keymap-select {
  case $KEYMAP in
    vicmd) echo -ne '\e[1 q';;      # blinking block for normal mode
    viins|main) echo -ne '\e[5 q';; # blinking beam for insert mode
  esac
}
function zle-line-init {
  echo -ne '\e[5 q'  # beam cursor on new line
}
zle -N zle-keymap-select
zle -N zle-line-init

{% endif %}

{% if shell_environment_atuin_integration | bool %}
# Atuin integration (MUST BE LAST - overwrites Ctrl+R)
if command -v atuin &> /dev/null; then
  eval "$(atuin init zsh)"
fi
{% endif %}

# Local customizations (not managed by Ansible)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# cd into /srv/apps if it exists
if [[ -d /srv/apps ]]; then
  cd /srv/apps
fi

# cd into /srv/infra if it exists
if [[ -d /srv/infra ]]; then
  cd /srv/infra
fi

# cd into /srv/media if it exists
if [[ -d /srv/media ]]; then
  cd /srv/media
fi
