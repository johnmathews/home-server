# vim: ft=yaml
groups:
  - name: ups_mains_rules
    interval: 3m
    rules:
      # Helper: "last seen OB timestamp", 0 otherwise
      - record: ups_ob_ts_seconds
        expr: |
          timestamp(network_ups_tools_ups_status{flag="OB"})
          * (network_ups_tools_ups_status{flag="OB"} == bool 1)

      # Last time OB was 1 (0 if not seen in the window)
      - record: ups_last_ob_timestamp_seconds
        expr: |
          max_over_time(ups_ob_ts_seconds[60d:30m])

      # First time we saw the OB metric in the window (series first-seen)
      - record: ups_first_seen_timestamp_seconds
        expr: |
          min_over_time(timestamp(network_ups_tools_ups_status{flag="OB"})[60d:30m])

      # Days on mains:
      # - real days since OB if an OB exists in the window
      # - otherwise -1 (means "unknown in window")
      - record: ups_days_on_mains
        expr: |
          (
            (time() - ups_last_ob_timestamp_seconds) / 86400
            and on(instance) (ups_last_ob_timestamp_seconds > 0)
          )
          or
          (
            (0 * ups_last_ob_timestamp_seconds - 1)
            and on(instance) (ups_last_ob_timestamp_seconds == 0)
          )

      # Days since last OB:
      # - same as above but forced to 0 while currently OB
      # - -1 if OB never seen in window
      - record: ups_days_since_last_ob
        expr: |
          (
            ((time() - ups_last_ob_timestamp_seconds) / 86400)
            * on(instance) (network_ups_tools_ups_status{flag="OB"} == bool 0)
            and on(instance) (ups_last_ob_timestamp_seconds > 0)
          )
          or
          (
            (0 * ups_last_ob_timestamp_seconds - 1)
            and on(instance) (ups_last_ob_timestamp_seconds == 0)
          )
