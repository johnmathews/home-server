# vim: ft=yaml

---

groups:
  - name: ups_mains_rules
    interval: 30s
    rules:
      # 1) Last time OB was 1 (0 if never seen in lookback)
      - record: ups_last_ob_timestamp_seconds
        expr: |
          max_over_time(
            ( timestamp(network_ups_tools_ups_status{flag="OB"})
              * (network_ups_tools_ups_status{flag="OB"} == bool 1)
            )[365d:20s]
          )

      # 2) First time we saw the metric at all (series first-seen)
      - record: ups_first_seen_timestamp_seconds
        expr: |
          min_over_time(
            timestamp(network_ups_tools_ups_status{flag="OB"})[365d:1m]
          )

      # 3) days on mains:
      - record: ups_days_on_mains
        expr: |
          (
            # Case 1: OB occurred -> real days since OB (keep only >0)
            ((time() - ups_last_ob_timestamp_seconds) / 86400)
            and on(instance) (ups_last_ob_timestamp_seconds > 0)
          )
          or
          (
            # Case 2: never on battery -> literal -1 (vectorized per instance)
            ((ups_last_ob_timestamp_seconds * 0) - 1)
            and on(instance) (ups_last_ob_timestamp_seconds == 0)
          )

      # 4) days since on battery:
      - record: ups_days_since_last_ob
        expr: |
          (
            # Days since last OB (masked to 0 if currently OB)
            ((time() - ups_last_ob_timestamp_seconds) / 86400)
            * on(instance) group_left()
              (network_ups_tools_ups_status{flag="OB"} == bool 0)
            and on(instance) (ups_last_ob_timestamp_seconds > 0)
          )
          or
          (
            # Never seen OB -> -1
            ((ups_last_ob_timestamp_seconds * 0) - 1)
            and on(instance) (ups_last_ob_timestamp_seconds == 0)
          )
