# vim: ft=yaml
groups:
  - name: ups_mains_rules
    interval: 3m
    rules:
      # Helper: "last seen OB timestamp", 0 otherwise
      - record: ups_ob_ts_seconds
        expr: |
          timestamp(network_ups_tools_ups_status{flag="OB"})
          * (network_ups_tools_ups_status{flag="OB"} == bool 1)

      # Last time OB was 1 (0 if not seen in the window)
      - record: ups_last_ob_timestamp_seconds
        expr: |
          max by(instance) (max_over_time(ups_ob_ts_seconds[60d:30m]))

      # Helper: "last seen OL timestamp", 0 otherwise
      - record: ups_ol_ts_seconds
        expr: |
          timestamp(network_ups_tools_ups_status{flag="OL"})
          * (network_ups_tools_ups_status{flag="OL"} == bool 1)

      # First time we saw OL=1 in the window (series first-seen)
      - record: ups_first_ol_timestamp_seconds
        expr: |
          min by(instance) (min_over_time(ups_ol_ts_seconds[60d:30m]))

      # Days on mains:
      # - real days since OB if an OB exists in the window
      # - otherwise -1 (means "unknown in window")
      - record: ups_days_on_mains
        expr: |
          (
            (time() - ups_last_ob_timestamp_seconds) / 86400
            and on(instance) (ups_last_ob_timestamp_seconds > 0)
          )
          or
          (
            (0 * ups_last_ob_timestamp_seconds - 1)
            and on(instance) (ups_last_ob_timestamp_seconds == 0)
          )

      - record: ups_days_since_last_ob
        expr: |
          clamp_min(
            (
              # Case A: OB seen before & currently NOT OB → days since last OB
              ((time() - ups_last_ob_timestamp_seconds) / 86400)
              * on(instance) (ups_last_ob_timestamp_seconds > bool 0)
              * on(instance) (network_ups_tools_ups_status{flag="OB"} == bool 0)
            )
            +
            (
              # Case B: OB never seen → time on mains (since first OL)
              ((time() - ups_first_ol_timestamp_seconds) / 86400)
              * on(instance) (ups_last_ob_timestamp_seconds == bool 0)
              * on(instance) (network_ups_tools_ups_status{flag="OB"} == bool 0)
            ),
            0
          )

