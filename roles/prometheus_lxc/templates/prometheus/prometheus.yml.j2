        target_label: client_name
        replacement: 'Media VM'
      - source_labels: [user]
        regex: '192\.168\.2\.11'
        target_label: client_name
        replacement: 'Ritsyas MacBook Air'
      - source_labels: [user]
        regex: '192\.168\.2\.12'
        target_label: client_name
        replacement: 'iPad'

  - job_name: 'container-status'
    scrape_interval: 30s
    scrape_timeout: 15s
    static_configs:
      - targets: ['192.168.2.106:8081']
        labels: {hostname: 'infra'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'

  - job_name: 'node_exporter'
    scrape_interval: 30s
    scrape_timeout: 15s
    static_configs:
      - targets: ['192.168.2.214:9100']
        labels: {hostname: 'proxmox'}
      - targets: ['192.168.2.104:9100']
        labels: {hostname: 'truenas'}
      - targets: ['192.168.2.105:9100']
        labels: {hostname: 'media'}
      - targets: ['192.168.2.106:9100']
        labels: {hostname: 'infra'}
      - targets: ['192.168.2.110:9100']
        labels: {hostname: 'jellyfin'}
      - targets: ['192.168.2.113:9100']
        labels: {hostname: 'immich'}
      - targets: ['192.168.2.115:9100']
        labels: {hostname: 'prometheus'}
      - targets: ['192.168.2.116:9100']
        labels: {hostname: 'tube-archivist'}
      - targets: ['192.168.2.117:9100']
        labels: {hostname: 'paperless'}
      - targets: ['192.168.2.119:9100']
        labels: {hostname: 'open-webui'}
      - targets: ['192.168.2.109:9100']
        labels: {hostname: 'navidrome'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'

  - job_name: 'home_assistant'
    metrics_path: /api/prometheus
    scheme: http
    scrape_timeout: 10s
    authorization:
      type: Bearer
      credentials: "{{ vault_home_assistant_token }}"
    static_configs:
      - targets: ['192.168.2.102:8123']
        labels: {hostname: 'home-assistant'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'

  - job_name: 'unbound'
    scrape_timeout: 10s
    static_configs:
      - targets: ['192.168.2.111:9167']
        labels: {hostname: 'unbound'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'
  - job_name: 'fastapi'
    scrape_interval: 60s
    scrape_timeout: 45s
    static_configs:
      - targets: ['192.168.2.201:8001']
        labels: {hostname: 'key-server'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'
  - job_name: 'ipmi'
    scrape_interval: 60s
    scrape_timeout: 15s
    static_configs:
      - targets: ['192.168.2.214:9290']
        labels: {hostname: 'proxmox'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'
  - job_name: 'smartctl'
    scrape_timeout: 10s
    static_configs:
      - targets: ['192.168.2.214:9633']
        labels: {hostname: 'proxmox'}
        # - targets: ['192.168.2.104:9633'] # stops hdd spin down.
        #   labels: {hostname: 'truenas'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'

  - job_name: 'pve_exporter'
    metrics_path: /pve
    scrape_timeout: 10s
    params:
      module: [default]
      cluster: ['1']
      node: ['1']
    static_configs:
      - targets: ['192.168.2.214:9221']
        labels: {hostname: 'proxmox'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'
  - job_name: 'disk_power_status_exporter'
    metrics_path: /metrics
    scrape_interval: 30s
    scrape_timeout: 15s
    static_configs:
      - targets: ['192.168.2.104:9635']
        labels: {hostname: 'truenas'}
      - targets: ['192.168.2.214:9635']
        labels: {hostname: 'proxmox'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'
    metric_relabel_configs:
      # drop unstable sdX label so reboots don't create new series
      - action: labeldrop
        regex: 'device'

  - job_name: 'nut'
    metrics_path: /ups_metrics
    scrape_interval: 30s
    scrape_timeout: 15s
    static_configs:
      - targets: ['192.168.2.214:9199']
        labels: {hostname: 'proxmox'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'

  - job_name: 'mikrotik_exporter'
    scrape_interval: 30s
    scrape_timeout: 15s
    static_configs:
      - targets: ['192.168.2.106:49090']
        labels: {hostname: 'mikrotik'}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+)(?::\d+)?'
        target_label: host
        replacement: '$1'
