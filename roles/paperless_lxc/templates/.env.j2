# vim: ft=jinja2
# Common user/group settings

PUID={{ puid }}
PGID={{ pgid }}

TZ={{ TZ }}

###############################################################################
# Paperless-ngx settings                                                      #
###############################################################################


# This is required if you will be exposing Paperless-ngx on a public domain
# (if doing so please consider security measures such as reverse proxy)
PAPERLESS_ALLOWED_HOSTS=docs.{{ primary_domain_name }},documents.{{ primary_domain_name }},paperless.{{ primary_domain_name }},192.168.2.117{% for d in migration_additional_domains | default([]) %},docs.{{ d }},documents.{{ d }},paperless.{{ d }}{% endfor %}

PAPERLESS_CORS_ALLOWED_HOSTS=https://paperless.{{ primary_domain_name }},https://docs.{{ primary_domain_name }},https://documents.{{ primary_domain_name }}{% for d in migration_additional_domains | default([]) %},https://paperless.{{ d }},https://docs.{{ d }},https://documents.{{ d }}{% endfor %}

PAPERLESS_CSRF_TRUSTED_ORIGINS=https://paperless.{{ primary_domain_name }},https://docs.{{ primary_domain_name }},https://documents.{{ primary_domain_name }}{% for d in migration_additional_domains | default([]) %},https://paperless.{{ d }},https://docs.{{ d }},https://documents.{{ d }}{% endfor %}

# See http://docs.paperless-ngx.com/configuration/ for all available options.

# The UID and GID of the user used to run paperless in the container. Set this
# to your UID and GID on the host so that you have write access to the
# consumption directory.
USERMAP_UID={{ puid }}
USERMAP_GID={{ pgid }}

# See the documentation linked above for all options. A few commonly adjusted settings
# are provided below.


# Adjust this key if you plan to make paperless available publicly. It should
# be a very long sequence of random characters. You don't need to remember it.
#PAPERLESS_SECRET_KEY=change-me

# Use this variable to set a timezone for the Paperless Docker containers. Defaults to UTC.
PAPERLESS_TIME_ZONE=Europe/Amsterdam

# PAPERLESS_OCR_LANGUAGE: The default language to use for OCR. Set this to the language most of your documents are written in.
# PAPERLESS_OCR_LANGUAGES: (plural!) Additional languages to install for text recognition, separated by a whitespace.
# Note that this is different from PAPERLESS_OCR_LANGUAGE (default=eng), which defines the language used for OCR.
# The container installs English, German, Italian, Spanish and French by default.
# See https://packages.debian.org/search?keywords=tesseract-ocr-&searchon=names&suite=buster for available languages.

PAPERLESS_OCR_LANGUAGES="eng nld"    # languages to INSTALL via apt (space-separated, lowercase)
PAPERLESS_OCR_LANGUAGE=eng+nld       # languages Paperless will USE (plus-separated, lowercase)

# Poll the consume dir every 10s
PAPERLESS_CONSUMER_POLLING=10
PAPERLESS_CONSUMER_RECURSIVE=1

PAPERLESS_FILENAME_FORMAT_REMOVE_NONE=true



###############################################################################
# Library settings (github.com/johnmathews/library)                          #
###############################################################################

# Internal docker-network credential for library-db (compose interpolates it).
LIBRARY_DB_PASSWORD={{ vault_library_db_password }}
{% if vault_library_anthropic_api_key is defined %}
# Claude API key for metadata extraction (from ansible vault). When absent,
# documents still OCR and index — extraction is skipped gracefully.
LIBRARY_ANTHROPIC_API_KEY={{ vault_library_anthropic_api_key }}
{% endif %}


LIBRARY_EMAIL_HOST=imap.gmail.com
LIBRARY_EMAIL_USERNAME={{ vault_library_gmail_email_address }}
LIBRARY_EMAIL_PASSWORD={{ vault_library_gmail_app_password }}
LIBRARY_EMAIL_POLL_MINUTES=10


# Public base URL of the web app (no trailing slash). Used to deep-link
# Pushover push notifications back to the document they refer to, so tapping
# a notification opens it in the app. Strongly recommended in production —
# unset = notifications arrive with no link (and the app logs a warning at
# startup). Set it to however you reach the web app from your phone.
LIBRARY_PUBLIC_BASE_URL={{ vault_library_public_base_url }} 
