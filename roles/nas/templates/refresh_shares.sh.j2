#!/usr/bin/env bash
# vim: ft=sh

# TrueNAS Share Refresh Script
# Workaround for TrueNAS bug where shares appear active but aren't functional
# Disables then re-enables NFS/SMB shares to ensure they're properly activated
# Usage: refresh_shares.sh

# Safer defaults
set -uo pipefail

# Optional bash -x tracing when DEBUG=1
export PS4='+ ts=$(date +%FT%T%z) line=${LINENO} cmd='
[[ "${DEBUG:-0}" == "1" ]] && set -x

# -------- configuration --------
SHARE_NFS_PATH="{{ refresh_shares_nfs_path }}"
SHARE_SMB_PATH="{{ refresh_shares_smb_path }}"
WAIT_SECONDS="{{ refresh_shares_wait_seconds | default(5) }}"
LOG_FILE="{{ refresh_shares_log_file | default('/mnt/swift/logs/refresh_shares.log') }}"

TRUENAS_API_URL="{{ truenas_api_url }}"
TRUENAS_API_KEY="{{ vault_truenas_api_key }}"

API_RETRIES="${API_RETRIES:-3}"
API_RETRY_DELAY_S="${API_RETRY_DELAY_S:-2}"
TRUENAS_API_TIMEOUT_S="${TRUENAS_API_TIMEOUT_S:-10}"

# -------- color codes --------
GREEN="\033[1;32m"
YELLOW="\033[1;33m"
RED="\033[1;31m"
BLUE="\033[1;34m"
RESET="\033[0m"

# -------- state tracking for cleanup --------
NFS_DISABLED=false
SMB_DISABLED=false
NFS_SHARE_ID=""
SMB_SHARE_ID=""

# -------- cleanup handler --------
cleanup() {
  local exit_code=$?

  # Only run cleanup if we've actually disabled shares
  if [[ "$NFS_DISABLED" == true ]] || [[ "$SMB_DISABLED" == true ]]; then
    echo "" >&2
    msg_color "$YELLOW" "[WARN] Script interrupted! Attempting to re-enable shares..." >&2

    # Try to re-enable any shares we disabled
    if [[ "$NFS_DISABLED" == true ]] && [[ -n "$NFS_SHARE_ID" ]]; then
      if enable_nfs_share "$NFS_SHARE_ID" "$SHARE_NFS_PATH" 2>/dev/null; then
        msg_color "$GREEN" "  [OK] Re-enabled NFS share" >&2
      else
        msg_color "$RED" "  [ERROR] Failed to re-enable NFS share - manual intervention required!" >&2
      fi
    fi

    if [[ "$SMB_DISABLED" == true ]] && [[ -n "$SMB_SHARE_ID" ]]; then
      if enable_smb_share "$SMB_SHARE_ID" "$SHARE_SMB_PATH" 2>/dev/null; then
        msg_color "$GREEN" "  [OK] Re-enabled SMB share" >&2
      else
        msg_color "$RED" "  [ERROR] Failed to re-enable SMB share - manual intervention required!" >&2
      fi
    fi
  fi

  exit $exit_code
}

# Register cleanup handler for interrupts and exits
trap cleanup EXIT INT TERM HUP

# -------- logging setup --------
# Redirect stdout and stderr to log file (fail gracefully if log unavailable)
if ! exec > >(tee -a "$LOG_FILE") 2>&1; then
  echo "WARNING: Cannot write to log file $LOG_FILE, logging to stdout only" >&2
fi

echo "────────────────────────────────────────────"
echo "Refresh script started at $(date)"
echo "────────────────────────────────────────────"
echo ""

# -------- logging with levels --------
_log_level="${LOG_LEVEL:-info}"
case "${_log_level}" in
debug) LOG_THRESH=10 ;;
info) LOG_THRESH=20 ;;
warn) LOG_THRESH=30 ;;
error) LOG_THRESH=40 ;;
*) LOG_THRESH=20 ;;
esac

level_num() {
  case "$1" in
  debug) echo 10 ;;
  info) echo 20 ;;
  warn) echo 30 ;;
  error) echo 40 ;;
  *) echo 20 ;;
  esac
}

should_log() {
  local want
  want=$(level_num "$1")
  [[ $want -ge $LOG_THRESH ]]
}

_log() {
  local level="$1" resource="$2" event="$3" reason="$4"
  shift 4
  if should_log "$level"; then
    printf 'ts=%s level=%s resource=%s action=%s event=%s reason=%s' \
      "$(date +%FT%T%z)" "$level" "${resource:-_}" "refresh" "$event" "$reason" >&2
    for kv in "$@"; do printf ' %s' "$kv" >&2; done
    printf '\n' >&2
  fi
}

log_debug() { _log debug "$@"; }
log_info() { _log info "$@"; }
log_warn() { _log warn "$@"; }
log_err() { _log error "$@"; }

# -------- human-readable messages --------
msg_color() {
  local color="$1"
  shift
  echo -e "${color}$*${RESET}"
}

fail_early() {
  _log error "_" "failed" "$1" "$2"
  msg_color "$RED" "[ERROR] $1: $2"
  exit "${3:-1}"
}

# -------- API helpers --------

# Validate JSON response
validate_json() {
  local json="$1"

  # Check if jq is available for proper validation
  if command -v jq >/dev/null 2>&1; then
    if ! jq empty 2>/dev/null <<<"$json"; then
      return 1
    fi

    # Check for error field in response
    if jq -e '.error' >/dev/null 2>&1 <<<"$json"; then
      local error_msg
      error_msg=$(jq -r '.error // "unknown"' 2>/dev/null <<<"$json")
      log_err "_" api_response "error_in_json" "error=$error_msg"
      return 1
    fi
  else
    # Fallback: basic JSON structure check
    if [[ ! "$json" =~ ^\[.*\]$ && ! "$json" =~ ^\{.*\}$ ]]; then
      return 1
    fi

    # Check for obvious error patterns
    if grep -qi '"error"' <<<"$json"; then
      log_warn "_" api_response "possible_error_in_json" "json=${json:0:100}"
      return 1
    fi
  fi

  return 0
}

# Make authenticated curl request to TrueNAS API
api_call() {
  local method="$1" endpoint="$2" data="${3:-}"
  local url="${TRUENAS_API_URL}${endpoint}"
  local attempt=1

  [[ -z "$TRUENAS_API_KEY" ]] && fail_early api_auth "TRUENAS_API_KEY not set" 1

  while :; do
    local output
    if [[ -z "$data" ]]; then
      output=$(curl -s -k --max-time "$TRUENAS_API_TIMEOUT_S" -X "$method" "$url" \
        -H "Authorization: Bearer ${TRUENAS_API_KEY}" \
        -H "Content-Type: application/json")
    else
      output=$(curl -s -k --max-time "$TRUENAS_API_TIMEOUT_S" -X "$method" "$url" \
        -H "Authorization: Bearer ${TRUENAS_API_KEY}" \
        -H "Content-Type: application/json" \
        -d "$data")
    fi
    local rc=$?

    if [[ $rc -eq 0 ]]; then
      # Validate JSON response
      if ! validate_json "$output"; then
        log_warn "_" api_call "invalid_json_response" "method=$method endpoint=$endpoint attempt=$attempt"
        if [[ $attempt -ge $API_RETRIES ]]; then
          log_err "_" api_call "invalid_json_after_retries" "method=$method endpoint=$endpoint"
          return 1
        fi
        attempt=$((attempt + 1))
        sleep "$API_RETRY_DELAY_S"
        continue
      fi

      log_debug "_" api_call "success" "method=$method endpoint=$endpoint"
      echo "$output"
      return 0
    else
      log_warn "_" api_call "curl_failed" "method=$method endpoint=$endpoint attempt=$attempt rc=$rc"
      if [[ $attempt -ge $API_RETRIES ]]; then
        log_err "_" api_call "failed_after_retries" "method=$method endpoint=$endpoint attempts=$API_RETRIES"
        return $rc
      fi
      attempt=$((attempt + 1))
      sleep "$API_RETRY_DELAY_S"
    fi
  done
}

# Get NFS share ID by path (with flexible matching)
get_nfs_share_id() {
  local dataset="$1"
  local response rc
  response=$(api_call GET "/sharing/nfs")
  rc=$?

  if [[ $rc -ne 0 ]]; then
    log_err "$dataset" nfs_share_api_failed "could not fetch NFS shares"
    return 1
  fi

  # Parse JSON to find share with matching path using jq if available
  local share_id
  if command -v jq >/dev/null 2>&1; then
    # Try exact path match first
    share_id=$(jq -r ".[] | select(.path==\"$dataset\") | .id" <<<"$response" 2>/dev/null | head -1)

    # If not found, try path variations
    if [[ -z "$share_id" ]] || [[ "$share_id" == "null" ]]; then
      # Try without /mnt prefix
      local short_path="${dataset#/mnt/}"
      share_id=$(jq -r ".[] | select(.path | endswith(\"/$short_path\")) | .id" <<<"$response" 2>/dev/null | head -1)

      # Try with /mnt prefix if not already there
      if [[ -z "$share_id" ]] || [[ "$share_id" == "null" ]]; then
        if [[ ! "$dataset" =~ ^/mnt/ ]]; then
          share_id=$(jq -r ".[] | select(.path==\"/mnt/$dataset\") | .id" <<<"$response" 2>/dev/null | head -1)
        fi
      fi
    fi

    log_debug "$dataset" share_lookup "result" "share_id=${share_id:-not_found} path=$dataset"
  else
    # Fallback: require jq for reliable operation
    log_err "$dataset" jq_required "jq is required for reliable share ID lookup"
    return 1
  fi

  if [[ -z "$share_id" ]] || [[ "$share_id" == "null" ]]; then
    log_warn "$dataset" nfs_share_not_found "share ID not found" "path=$dataset"
    return 1
  fi
  echo "$share_id"
  return 0
}

# Get SMB share ID by path (with flexible matching)
get_smb_share_id() {
  local dataset="$1"
  local response rc
  response=$(api_call GET "/sharing/smb")
  rc=$?

  if [[ $rc -ne 0 ]]; then
    log_err "$dataset" smb_share_api_failed "could not fetch SMB shares"
    return 1
  fi

  # Parse JSON to find share with matching path using jq if available
  local share_id
  if command -v jq >/dev/null 2>&1; then
