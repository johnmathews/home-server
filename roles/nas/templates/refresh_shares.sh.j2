    return 1
  fi

  log_info "$dataset" smb_enable "success" "share_id=$share_id verified=true"
  return 0
}

# -------- TrueNAS health check --------

# Check if TrueNAS API is accessible
check_truenas_health() {
  log_debug "_" truenas_health "checking" "url=$TRUENAS_API_URL"

  # Try to GET /system/info (lightweight endpoint)
  local response
  response=$(api_call GET "/system/info" 2>/dev/null)

  if [[ -z "$response" ]]; then
    log_err "_" truenas_health "failed" "cannot_reach_api"
    return 1
  fi

  if command -v jq >/dev/null 2>&1; then
    local version
    version=$(jq -r '.version // "unknown"' <<<"$response" 2>/dev/null)
    log_info "_" truenas_health "ok" "version=$version"
  else
    log_info "_" truenas_health "ok" "response_received"
  fi

  return 0
}

# -------- main refresh function --------

refresh_shares() {

  # the script runs POSTINIT with a 60second timeout.
  # Initial delay to let middleware and services start properly
  sleep 5

  msg_color "$BLUE" "[INFO] Verifying TrueNAS API health..."

  if ! check_truenas_health; then
    fail_early truenas_unreachable "TrueNAS API is not accessible" 1
  fi
  msg_color "$GREEN" "  [OK] TrueNAS API accessible"
  echo ""

  msg_color "$BLUE" "[INFO] Looking up share IDs..."

  # Get NFS share ID with retry logic
  local nfs_id
  nfs_id=$(get_share_id_with_retry "nfs" "$SHARE_NFS_PATH")
  if [[ -z "$nfs_id" ]]; then
    fail_early nfs_lookup_failed "Could not find NFS share: $SHARE_NFS_PATH" 1
  fi
  NFS_SHARE_ID="$nfs_id" # Track for cleanup
  msg_color "$GREEN" "  [OK] NFS share $SHARE_NFS_PATH → ID: $nfs_id"

  # Get SMB share ID with retry logic
  local smb_id
  smb_id=$(get_share_id_with_retry "smb" "$SHARE_SMB_PATH")
  if [[ -z "$smb_id" ]]; then
    fail_early smb_lookup_failed "Could not find SMB share: $SHARE_SMB_PATH" 1
  fi
  SMB_SHARE_ID="$smb_id" # Track for cleanup
  msg_color "$GREEN" "  [OK] SMB share $SHARE_SMB_PATH → ID: $smb_id"
  echo ""

  msg_color "$BLUE" "[INFO] Disabling shares..."

  # Disable NFS
  if ! disable_nfs_share "$nfs_id" "$SHARE_NFS_PATH"; then
    fail_early nfs_disable_failed "Failed to disable NFS share" 1
  fi
  NFS_DISABLED=true # Mark as disabled for cleanup
  msg_color "$GREEN" "  [OK] Disabled NFS share (ID: $nfs_id)"

  # Disable SMB
  if ! disable_smb_share "$smb_id" "$SHARE_SMB_PATH"; then
    fail_early smb_disable_failed "Failed to disable SMB share" 1
  fi
  SMB_DISABLED=true # Mark as disabled for cleanup
  msg_color "$GREEN" "  [OK] Disabled SMB share (ID: $smb_id)"
  echo ""

  msg_color "$YELLOW" "[INFO] Waiting ${WAIT_SECONDS} seconds..."
  sleep "$WAIT_SECONDS"
  echo ""

  msg_color "$BLUE" "[INFO] Enabling shares..."

  # Enable NFS
  if ! enable_nfs_share "$nfs_id" "$SHARE_NFS_PATH"; then
    fail_early nfs_enable_failed "Failed to enable NFS share" 1
  fi
  NFS_DISABLED=false # Mark as re-enabled (no cleanup needed)
  msg_color "$GREEN" "  [OK] Enabled NFS share (ID: $nfs_id)"

  # Enable SMB
  if ! enable_smb_share "$smb_id" "$SHARE_SMB_PATH"; then
    fail_early smb_enable_failed "Failed to enable SMB share" 1
  fi
  SMB_DISABLED=false # Mark as re-enabled (no cleanup needed)
  msg_color "$GREEN" "  [OK] Enabled SMB share (ID: $smb_id)"
  echo ""

  msg_color "$GREEN" "[OK] Share refresh complete!"
  log_info "_" refresh "complete" "status=success"
  echo ""

  return 0
}

# -------- main --------

# Pre-flight checks
if ! command -v curl >/dev/null 2>&1; then
  fail_early missing_dependency "curl is required but not installed" 2
fi

if ! command -v jq >/dev/null 2>&1; then
  fail_early missing_dependency "jq is required but not installed" 2
fi

# Run the refresh
log_info "_" refresh "start" "nfs=$SHARE_NFS_PATH smb=$SHARE_SMB_PATH"
refresh_shares
exit $?
