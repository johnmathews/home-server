  return 0
}

# Retry wrapper for share lookups - handles timing issues during boot
# Uses progressive backoff to avoid hammering TrueNAS during initialization
# With 60s timeout, we can be more patient and thorough
get_share_id_with_retry() {
  local share_type="$1" dataset="$2"
  local max_attempts=8  # Increased from 6 with 60s timeout
  local attempt=1

  log_debug "$dataset" "${share_type}_lookup" "starting_with_retry" "max_attempts=$max_attempts"

  while [[ $attempt -le $max_attempts ]]; do
    local share_id

    if [[ "$share_type" == "nfs" ]]; then
      share_id=$(get_nfs_share_id "$dataset" 2>/dev/null)
    elif [[ "$share_type" == "smb" ]]; then
      share_id=$(get_smb_share_id "$dataset" 2>/dev/null)
    else
      log_err "$dataset" share_lookup "invalid_type" "type=$share_type"
      return 1
    fi

    if [[ -n "$share_id" && "$share_id" != "null" ]]; then
      log_info "$dataset" "${share_type}_lookup" "found" "share_id=$share_id attempt=$attempt"
      echo "$share_id"
      return 0
    fi

    if [[ $attempt -lt $max_attempts ]]; then
      # Progressive backoff: start fast, slow down if service not ready
      # Attempts 1-2: 1s wait (quick checks)
      # Attempts 3-4: 2s wait (moderate patience)
      # Attempts 5-6: 3s wait (more patience)
      # Attempts 7-8: 4s wait (very patient for slow systems)
      local wait_time
      if [[ $attempt -le 2 ]]; then
        wait_time=1
      elif [[ $attempt -le 4 ]]; then
        wait_time=2
      elif [[ $attempt -le 6 ]]; then
        wait_time=3
      else
        wait_time=4
      fi

      log_debug "$dataset" "${share_type}_lookup" "retry" "attempt=$attempt waiting=${wait_time}s"
      sleep $wait_time
    fi

    attempt=$((attempt + 1))
  done

  log_err "$dataset" "${share_type}_lookup" "failed_after_retries" "attempts=$max_attempts"
  return 1
}

# Verify share state
verify_share_state() {
  local share_type="$1" share_id="$2" expected_state="$3" dataset="$4"

  local verify
  verify=$(api_call GET "/sharing/${share_type}/id/$share_id")

  if [[ -z "$verify" ]]; then
    log_warn "$dataset" "${share_type}_verify" "failed_to_get_state" "share_id=$share_id"
    return 1
  fi

  if command -v jq >/dev/null 2>&1; then
    local actual_state jq_error
    actual_state=$(jq -r '.enabled | tostring' <<<"$verify" 2>/dev/null)
    jq_error=$?

    # Convert boolean strings to lowercase for comparison
    actual_state=$(echo "$actual_state" | tr '[:upper:]' '[:lower:]')

    # Check if jq failed or returned null
    if [[ $jq_error -ne 0 ]] || [[ "$actual_state" == "null" ]]; then
      log_warn "$dataset" "${share_type}_verify" "cannot_determine_state" "jq_rc=$jq_error actual=$actual_state"
      return 1
    fi

    if [[ "$actual_state" == "$expected_state" ]]; then
      log_debug "$dataset" "${share_type}_verify" "ok" "share_id=$share_id enabled=$actual_state"
      return 0
    else
      log_err "$dataset" "${share_type}_verify" "state_mismatch" "share_id=$share_id expected=$expected_state actual=$actual_state"
      return 1
    fi
  else
    # Without jq, skip verification
    log_debug "$dataset" "${share_type}_verify" "skipped" "jq_unavailable"
    return 0
  fi
}

# Disable NFS share by ID
disable_nfs_share() {
  local share_id="$1" dataset="$2"
  local data='{"enabled":false}'

  if ! api_call PUT "/sharing/nfs/id/$share_id" "$data" >/dev/null 2>&1; then
    log_warn "$dataset" nfs_disable "api_failed" "share_id=$share_id"
    return 1
  fi

  # Verify state change
  if ! verify_share_state "nfs" "$share_id" "false" "$dataset"; then
    log_warn "$dataset" nfs_disable "verification_failed" "share_id=$share_id may_not_be_disabled"
    return 1
  fi

  log_info "$dataset" nfs_disable "success" "share_id=$share_id verified=true"
  return 0
}

# Enable NFS share by ID
enable_nfs_share() {
  local share_id="$1" dataset="$2"
  local data='{"enabled":true}'

  if ! api_call PUT "/sharing/nfs/id/$share_id" "$data" >/dev/null 2>&1; then
    log_warn "$dataset" nfs_enable "api_failed" "share_id=$share_id"
    return 1
  fi

  # Verify state change
  if ! verify_share_state "nfs" "$share_id" "true" "$dataset"; then
    log_warn "$dataset" nfs_enable "verification_failed" "share_id=$share_id may_not_be_enabled"
    return 1
  fi

  log_info "$dataset" nfs_enable "success" "share_id=$share_id verified=true"
  return 0
}

# Disable SMB share by ID
disable_smb_share() {
  local share_id="$1" dataset="$2"
  local data='{"enabled":false}'

  if ! api_call PUT "/sharing/smb/id/$share_id" "$data" >/dev/null 2>&1; then
