  return 0
}

# Enable SMB share by ID
enable_smb_share() {
  local share_id="$1" dataset="$2"
  local data='{"enabled":true}'

  if ! api_call PUT "/sharing/smb/id/$share_id" "$data" >/dev/null 2>&1; then
    log_warn "$dataset" smb_enable "api_failed" "share_id=$share_id"
