# {{ ansible_managed }}
soulseek:
  username: {{ vault_slskd_soulseek_username }}
  password: {{ vault_slskd_soulseek_password }}
  listen_port: 50300
  description: A slskd user.

directories:
  downloads: /downloads

shares:
  directories:
    - /music/releases
  filters:
    - \.ini$
    - Thumbs.db$
    - \.DS_Store$

global:
  upload:
    slots: 20
    speed_limit: 1000
  download:
    slots: 500
    speed_limit: 1000

web:
  port: 5030
  url_base: /
  authentication:
    username: {{ vault_slskd_web_username }}
    password: {{ vault_slskd_web_password }}
    api_keys:
      soularr:
        key: {{ vault_slskd_api_key }}
        role: readwrite
        cidr: 0.0.0.0/0,::/0

integration:
  vpn:
    enabled: false
