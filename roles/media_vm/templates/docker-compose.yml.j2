# vim: ft=yaml
# media_vm/files/docker-compose.yml
services:

  lidarr:
    image: lscr.io/linuxserver/lidarr:latest
    container_name: lidarr
    user: "${PUID}:${PGID}"
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - UMASK=002
      - TZ=${TZ}
    volumes:
      - /srv/media/config/lidarr:/config
      - /mnt/nfs/music:/music
      - /mnt/nfs/downloads:/downloads
    ports:
      - "8686:8686"
    restart: always

  slskd:
    image: slskd/slskd:latest
    container_name: slskd
    user: "${PUID}:${PGID}"
    environment:
      - SLSKD_REMOTE_CONFIGURATION=true
      - TZ=${TZ}
    volumes:
      - /srv/media/config/slskd:/app
      - /mnt/nfs/downloads/slskd:/downloads
      - /mnt/nfs/music:/music:ro
    network_mode: "service:gluetun"
    depends_on:
      gluetun:
        condition: service_healthy
    restart: always

  soularr:
    image: mrusse08/soularr:latest
    container_name: soularr
    user: "${PUID}:${PGID}"
    environment:
      - TZ=${TZ}
      - SCRIPT_INTERVAL=300
    volumes:
      - /srv/media/config/soularr:/data
      - /mnt/nfs/downloads/slskd:/downloads
    restart: always

  gluetun:
    image: qmcgaw/gluetun
    container_name: gluetun
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun
    ports:
      - 8080:8080 # qBittorrent WebUI
      - 3189:3189 # qbittorrent endpoint port
      - 6881:6881 # BitTorrent port
      - 8081:8081 # sabnzbd WebUI, set in config file.
      - 6881:6881/udp
      - 8000:8000/tcp # control server port
      - 5030:5030 # slskd WebUI
      - 50300:50300 # Soulseek P2P
    volumes:
      - /srv/media/config/gluetun:/gluetun
    healthcheck:
      test: ["CMD", "wget", "-qO-", "https://ifconfig.me"]
      interval: 90s
      timeout: 15s
      retries: 3
    environment:
      # NO PORT FORWARDING 
      - FIREWALL=on
      - FIREWALL_VPN_INPUT_PORTS="3189,6881,50300"
      - VPN_SERVICE_PROVIDER=${VPN_SERVICE_PROVIDER}
      - VPN_TYPE=wireguard
      - WIREGUARD_ENDPOINT=${WIREGUARD_ENDPOINT}
      - WIREGUARD_PUBLIC_KEY=${WIREGUARD_PUBLIC_KEY}
      - WIREGUARD_PRIVATE_KEY=${WIREGUARD_PRIVATE_KEY}
      - WIREGUARD_ADDRESSES=${WIREGUARD_ADDRESSES}
      - OWNED_ONLY=yes
      - TZ=Europe/Amsterdam
    restart: always

  qbittorrent:
    image: linuxserver/qbittorrent
    container_name: qbittorrent
    security_opt:
      - no-new-privileges:true
    network_mode: "service:gluetun"
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - UMASK=002
      - TZ=${TZ}
      - WEBUI_USERNAME=${QBITTORRENT_USERNAME}
      - WEBUI_PASSWORD=${QBITTORRENT_PASSWORD}
    volumes:
      - /srv/media/config:/config
      - /mnt/nfs/downloads:/downloads
      - /mnt/nfs/library:/media
    restart: always
    depends_on:
      gluetun:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS --connect-timeout 2 http://127.0.0.1:8080/ >/dev/null || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s

  # smb shares
  sabnzbd:
    image: lscr.io/linuxserver/sabnzbd:latest
    container_name: sabnzbd
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - UMASK=002
      - TZ=${TZ}
      - HOST_WHITELIST=sabnzbd.itsa.pizza,192.168.2.118 # doesnt work for this image. edit sabnzbd.ini instead
    volumes:
      - /srv/media/config/sabnzbd:/config # Persistent settings
      - /mnt/nfs/downloads:/downloads
      - /mnt/nfs/library:/library
    network_mode: "service:gluetun"
    depends_on:
      gluetun:
        condition: service_healthy
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    restart: always

  booklore:
    image: booklore/booklore:latest
    container_name: booklore
    environment:
      - USER_ID=1001
      - GROUP_ID=1001
      - PUID=1001
      - PGID=1001
      - TZ=Europe/Amsterdam
      - BOOKLORE_PORT=6060
      - DATABASE_URL=jdbc:mariadb://booklore-mariadb:3306/booklore
      - DATABASE_USERNAME=booklore
      - DATABASE_PASSWORD=${BOOKLORE_DB_PASSWORD}
    env_file: .env
    depends_on:
      booklore-mariadb:
        condition: service_healthy
    ports:
      - "6060:6060"
    volumes:
      - /srv/media/config/booklore/data:/app/data
      - /srv/media/config/booklore/books:/books
      - /srv/media/config/booklore/bookdrop:/bookdrop
      - /mnt/nfs/books:/nfs/books
      - /mnt/nfs/library:/nfs/library:ro
      - /mnt/nfs/media:/nfs/media:ro
    restart: always

  booklore-mariadb:
    image: lscr.io/linuxserver/mariadb:11.4.5
    container_name: booklore-mariadb
    environment:
      - PUID=1001
      - PGID=1001
      - TZ=Europe/Amsterdam
      - MYSQL_ROOT_PASSWORD=${BOOKLORE_DB_ROOT_PASSWORD}
      - MYSQL_DATABASE=booklore
      - MYSQL_USER=booklore
      - MYSQL_PASSWORD=${BOOKLORE_DB_PASSWORD}
    env_file: .env
    volumes:
      - /srv/media/config/booklore/mariadb/config:/config
    restart: always
    healthcheck:
      test: ["CMD", "mariadb-admin", "ping", "-h", "localhost"]
      interval: 5s
      timeout: 5s
      retries: 10

  sonarr:
    image: linuxserver/sonarr:latest
    container_name: sonarr
    user: "${PUID}:${PGID}"
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - UMASK=002
      - TZ=${TZ}
    volumes:
      - /usr/local/bin:/usr/local/bin
      - /srv/media/config/sonarr:/config
      - /mnt/nfs/library:/library
      - /mnt/nfs/downloads:/downloads # keep this so it understands what sabnzbd sees
    ports:
      - "8989:8989"
    restart: always

  radarr:
    image: linuxserver/radarr:latest
    container_name: radarr
    user: "${PUID}:${PGID}"
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - UMASK=002
      - TZ=${TZ}
    volumes:
      - /usr/local/bin:/usr/local/bin
      - /srv/media/config/radarr:/config
      - /mnt/nfs/library:/library
      - /mnt/nfs/downloads:/downloads # keep this so it understands what sabnzbd sees
    ports:
      - "7878:7878"
    restart: always

  flaresolverr:
    # DockerHub mirror flaresolverr/flaresolverr:latest
    image: ghcr.io/flaresolverr/flaresolverr:latest
    container_name: flaresolverr
    environment:
      - LOG_LEVEL=${LOG_LEVEL:-info}
      - LOG_HTML=${LOG_HTML:-false}
      - CAPTCHA_SOLVER=${CAPTCHA_SOLVER:-none}
      - TZ=${TZ}
    ports:
      - "${PORT:-8191}:8191"
    restart: always

  prowlarr:
    image: lscr.io/linuxserver/prowlarr:latest
    container_name: prowlarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    volumes:
      - /srv/media/config/prowlarr:/config
    ports:
      - "9696:9696"
    restart: always

  jellyseerr:
    image: fallenbagel/jellyseerr:latest
    container_name: jellyseerr
    ports:
      - 5055:5055
    environment:
      - LOG_LEVEL=info
    volumes:
      - /srv/media/config/jellyseer:/app/config
    restart: always

  bazarr:
    image: linuxserver/bazarr
    container_name: bazarr
    ports:
      - "6767:6767"
    user: "${PUID}:${PGID}"
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    volumes:
      - /srv/media/config/bazarr:/config
      - /mnt/nfs/library:/library
    restart: always

  alloy:
    image: grafana/alloy:latest
    container_name: alloy
    restart: always
    environment:
      LOKI_WRITE_ENDPOINT: "http://192.168.2.106:3100/loki/api/v1/push"
      NODE_HOSTNAME: "media"
      LOG_LEVEL: "warn"
    volumes:
      # config 
      - ./config/alloy:/etc/alloy:ro
      # docker 
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      # journalctl  
      - /var/log/journal:/var/log/journal:ro
      - /run/log/journal:/run/log/journal:ro
      - /etc/machine-id:/etc/machine-id:ro
    command: >
      run --server.http.listen-addr=0.0.0.0:12345 --storage.path=/var/lib/alloy/data /etc/alloy/config.alloy
    ports:
      - "12345:12345"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  node_exporter:
    image: quay.io/prometheus/node-exporter:latest
    container_name: node_exporter
    command:
      - '--path.rootfs=/host'
      - '--collector.textfile.directory=/textfile'
    # network_mode: host
    ports:
      - "9100:9100"
    pid: host
    restart: always
    volumes:
      - '/:/host:ro,rslave'
      - '/var/lib/node_exporter/textfile_collector:/textfile:ro'

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:latest
    container_name: cadvisor
    restart: unless-stopped
    ports:
      - "18080:8080"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /sys/fs/cgroup:/sys/fs/cgroup:ro
      - /var/lib/docker:/var/lib/docker:ro
      - /var/lib/containerd:/var/lib/containerd:ro
    read_only: true
    tmpfs:
      - /tmp
    security_opt:
      - no-new-privileges:true
