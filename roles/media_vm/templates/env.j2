# Generated .env file for media stack

# Common user/group settings
PUID={{ PUID }}
PGID={{ PGID }}
TZ={{ TZ }}

# Service credentials
{% for service, user in media_stack_users.items() %}
{{ service | upper }}_USERNAME={{ user.username }}
{{ service | upper }}_PASSWORD={{ lookup('vars', 'vault_' ~ service ~ '_' ~ user.username ~ '_password') }}
{% endfor %}


CONFIG_DIR=/srv/media/config
MEDIA_DIR=/srv/media/library
DOWNLOAD_DIR=/srv/media/downloads
