# Common user/group settings
PUID={{ puid }}
PGID={{ guid }}

TZ={{ TZ }}

COMPOSE_PROJECT_NAME=media

# media_stack_config_dir is `/srv/media/config`
# media_stack_mount_dir is `/mnt/media`

CONFIG_DIR={{ media_stack_base_dir }}

# media_stack_mount_dir: /mnt/media
DOWNLOAD_DIR={{ media_stack_mount_dir }}/library/downloads
MEDIA_DIR={{ media_stack_mount_dir }}/library

QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD={{ vault_qbittorrent_password }}

WIREGUARD_PRIVATE_KEY={{ vault_wireguard_private_key }}
WIREGUARD_ADDRESSES={{ vault_wireguard_addresses }}
WIREGUARD_PUBLIC_KEY={{ vault_wireguard_public_key }}
WIREGUARD_ENDPOINT={{ vault_wireguard_endpoint }}
VPN_SERVICE_PROVIDER={{ vault_vpn_service_provider }}

BOOKLORE_DB_PASSWORD={{ vault_booklore_db_password }}
BOOKLORE_DB_ROOT_PASSWORD={{ vault_booklore_db_root_password }}

ANTHROPIC_API_KEY={{ vault_anthropic_api_key }}
OPENAI_API_KEY={{ vault_openai_api_key }}

MCP_ALLOWED_HOSTS={{ vault_mcp_allowed_hosts }}

SLACK_BOT_TOKEN={{ vault_slack_bot_token }}
JOURNAL_API_TOKEN={{ vault_journal_api_token }}
GOOGLE_GEMINI_JOURNAL_INSIGHTS_API_KEY={{ vault_google_gemini_journal_insights_api_key }}
JOURNAL_INSIGHTS_APP_OCR_PROVIDER=gemini

# gemini-2.5-flash is almost as good and much cheaper. check exact name
OCR_MODEL=gemini-2.5-pro
