# Generated .env file for media stack

# Common user/group settings
PUID={{ qbittorrent_uid | default(3002) }}
PGID={{ qbittorrent_gid | default(3002) }}

TZ={{ TZ }}

# Service credentials
{% for service, user in media_stack_users.items() %}
{{ service | upper }}_USERNAME={{ user.username }}
{{ service | upper }}_PASSWORD={{ lookup('vars', 'vault_' ~ service ~ '_' ~ user.username ~ '_password') }}
{% endfor %}

# media_stack_config_dir is `/srv/media/config`
# media_stack_mount_dir is `/mnt/media`

CONFIG_DIR={{ media_stack_config_dir }}
DOWNLOAD_DIR={{ media_stack_mount_dir }}/library/downloads
MEDIA_DIR={{ media_stack_mount_dir }}/library



QBITTORRENT_USERNAME={{ media_stack_users.qbittorrent.username }}
QBITTORRENT_PASSWORD={{ lookup('vars', 'vault_qbittorrent_' ~ media_stack_users.qbittorrent.username ~ '_password') }}
