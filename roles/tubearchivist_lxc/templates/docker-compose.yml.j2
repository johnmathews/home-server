# vim: ft=yaml
# jellyfin_lxc/files/docker-compose.yml

services:

  portainer-agent:
    image: portainer/agent:{{ portainer_agent_version }}
    container_name: portainer_agent
    restart: always
    environment:
      # Shared secret: only the Portainer server (same secret) can control this agent
      AGENT_SECRET: "{{ vault_portainer_agent_secret }}"
    ports:
      - "9001:9001"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  tubearchivist:
    image: bbilly1/tubearchivist:{{ tubearchivist_version }}
    container_name: tubearchivist
    restart: always
    ports:
      - 8000:8000
    volumes:
      - /mnt/nfs/youtube-kids:/youtube
      - cache:/cache
    environment:
      - TZ=Europe/Amsterdam
      - HOST_UID=1000
      - HOST_GID=1000
      - ES_URL=http://archivist-es:9200
      - ELASTIC_PASSWORD={{ vault_ta_elastic_search_password }}
      - REDIS_CON=redis://archivist-redis:6379
      - TA_HOST={{ tubearchivist_host }}
      - TA_USERNAME={{ ta_username }}
      - TA_PASSWORD={{ vault_ta_password }}
      - TA_AUTO_UPDATE_YTDLP=release
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/api/health/"]
      interval: 1m
      timeout: 5s
      retries: 3
      start_period: 30s
    depends_on:
      archivist-es:
        condition: service_started
      archivist-redis:
        condition: service_healthy
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  archivist-redis:
    image: redis/redis-stack-server:7.4.0-v3
    container_name: archivist-redis
    restart: always
    expose:
      - "6379"
    volumes:
      - redis:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    depends_on:
      - archivist-es
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  archivist-es:
    image: elasticsearch:8.18.0
    container_name: archivist-es
    restart: always
    environment:
      - "ELASTIC_PASSWORD={{ vault_ta_elastic_search_password }}"
      - "ES_JAVA_OPTS=-Xms1g -Xmx1g"
      - "xpack.security.enabled=true"
      - "discovery.type=single-node"
      - "path.repo=/usr/share/elasticsearch/data/snapshot"
    ulimits:
      memlock:
        soft: -1
        hard: -1
    volumes:
      - es:/usr/share/elasticsearch/data
    expose:
      - "9200"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  alloy:
    image: grafana/alloy:{{ alloy_version }}
    container_name: alloy
    restart: unless-stopped
    environment:
      LOKI_WRITE_ENDPOINT: "http://192.168.2.106:3100/loki/api/v1/push"
      NODE_HOSTNAME: "tube-archivist"
      LOG_LEVEL: "warn"
    volumes:
      # config 
      - ./alloy:/etc/alloy:ro
      # docker 
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      # journalctl  
      - /var/log/journal:/var/log/journal:ro
      - /run/log/journal:/run/log/journal:ro
      - /etc/machine-id:/etc/machine-id:ro
    command: >
      run --server.http.listen-addr=0.0.0.0:12345 --stability.level=experimental --storage.path=/var/lib/alloy/data /etc/alloy/config.alloy
    ports:
      - "12345:12345"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  node_exporter:
    image: quay.io/prometheus/node-exporter:{{ node_exporter_version }}
    container_name: node_exporter
    command:
      - '--path.rootfs=/host'
      - '--collector.textfile.directory=/textfile'
    ports:
      - "9100:9100"
    pid: host
    restart: unless-stopped
    volumes:
      - '/:/host:ro,rslave'
      - '/var/lib/node_exporter/textfile_collector:/textfile:ro'
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:{{ cadvisor_version }}
    container_name: cadvisor
    restart: always
    ports:
      - "18080:8080"
    volumes:
      - /:/rootfs:ro
      - /sys:/sys:ro
      - /sys/fs/cgroup:/sys/fs/cgroup:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /var/run:/var/run:ro
    privileged: false # required for some metrics, but `true` makes it scan /dev/** and in an LXC /dev/series/by-id does not exist.
    security_opt:
      - no-new-privileges:true
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"

volumes:
  media:
  cache:
  redis:
  es:
