# playbooks/validate-paths.yml

---

- name: Validate host paths for media stack
  hosts: localhost
  gather_facts: false
  vars:
    download_dir: "{{ media_stack_base_dir }}/downloads"
    media_dir: "{{ media_stack_base_dir }}/library"
    docker_volume_string: "{{ lookup('file', 'docker-compose.yaml') }}"
  tasks:
    - import_role:
        name: media_vm
      tasks_from: validate_paths
