# .ansible-lint - Project-specific linting rules

# Rules we *allow* to fail the build
enable_list:
  - all

# Rules we *want to see*, but not fail the build yet
warn_list:
   - fqcn                            # Migrating to fully qualified module names (in progress)
   - var-naming                      # Gradually prefix variables inside roles
   - no-changed-when                 # Flag missing changed_when where needed
   - risky-file-permissions          # Warn if mode: is missing on sensitive files
   - yaml[line-length]              # Non-blocking formatting issues
   - package-latest                  # pip upgrades commonly use state: latest

# Files to exclude
exclude_paths:
  - .venv/
  - cloud-images/
  - iso-images/
  - roles/shell_environment/files/nvim-custom/  # Editor config with intentional YAML errors for diagnostics

# Optional: reduce noise when using roles downloaded with ansible-galaxy
skip_list:
  - experimental                   # Skip experimental rules for now
